#!/usr/bin/env bash
# =============================================================================
#  firesim-lab — simulation environment launcher
#
#  Installed once to ~/.firesim-lab/docker/ and symlinked into your PATH by
#  install.sh.  Run from any workspace directory.
#
#  On first run in a new directory (no .firesim-lab.env):
#    Auto-detects any existing firesim-lab project in the workspace.
#    Prompts for image/thread settings, writes .firesim-lab.env, starts the
#    container, and drops you into a shell.
#
#  On subsequent runs (.firesim-lab.env already exists):
#    Reads saved settings silently, starts or enters the container.
#
#  Usage:
#    cd ~/my-workspace && firesim-lab                  # start / enter
#    cd ~/my-workspace && firesim-lab --down           # stop container
#    cd ~/my-workspace && firesim-lab --pull           # pull fresh image
#    cd ~/my-workspace && firesim-lab --reconfigure    # re-prompt settings
#    cd ~/my-workspace && firesim-lab --status         # show container info
#    cd ~/my-workspace && firesim-lab --clean-cache    # wipe SBT/ccache volumes
#
#  Non-interactive (CI / scripted):
#    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab
# =============================================================================

set -euo pipefail

# ── Pipe-detection guard ──────────────────────────────────────────────────────
_first_arg="${1:-}"
_non_interactive_safe=0
case "$_first_arg" in
  -h|--help|--down|--pull|--clean-cache|--status) _non_interactive_safe=1 ;;
esac

if [[ ! -t 0 && $_non_interactive_safe -eq 0 ]]; then
  cat >&2 <<PIPE_ERR

  ERROR: firesim-lab cannot be piped directly.

  It uses interactive prompts and must be run from a local installation.
  The correct entry point is install.sh:

    curl -sSL https://raw.githubusercontent.com/pentarisc/firesim-lab/main/install.sh | bash

PIPE_ERR
  exit 1
fi

# ── Locate installation directory ─────────────────────────────────────────────
# Resolve symlinks so INSTALL_DIR always points to the real installation folder
# even when invoked through a PATH symlink.
_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" && pwd
}
INSTALL_DIR="$(_resolve_script_dir)"

# ── Workspace is always the current working directory ─────────────────────────
WORKSPACE_DIR="$(pwd)"
WORKSPACE_BASENAME="$(basename "$WORKSPACE_DIR")"
ENV_FILE="$WORKSPACE_DIR/.firesim-lab.env"

# ── Static configuration ──────────────────────────────────────────────────────
REPO_RAW="https://raw.githubusercontent.com/pentarisc/firesim-lab/main"
COMPOSE_URL="${REPO_RAW}/docker/docker-compose.yaml"
COMPOSE_FILE="$INSTALL_DIR/docker-compose.yaml"

DEFAULT_IMAGE="firesim-lab:latest"
DEFAULT_VERILATOR_THREADS=$(nproc 2>/dev/null || echo 4)
DEFAULT_MEMORY_LIMIT="16g"
DEFAULT_MEMORY_RESERVE="8g"

# Container name is workspace-scoped only — one container per workspace.
# Illegal docker name characters are replaced with '-'.
CONTAINER_NAME="firesim-lab-$(echo "$WORKSPACE_BASENAME" | tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/-*$//')"

# ── Colour helpers ────────────────────────────────────────────────────────────
_bold()  { printf '\033[1m%s\033[0m' "$*"; }
_green() { printf '\033[32m%s\033[0m' "$*"; }
_cyan()  { printf '\033[36m%s\033[0m' "$*"; }
_yellow(){ printf '\033[33m%s\033[0m' "$*"; }
_red()   { printf '\033[31m%s\033[0m' "$*"; }

# ── Help ──────────────────────────────────────────────────────────────────────
usage() {
  cat <<USAGE

  $(_bold "firesim-lab") — FireSim standalone simulation environment

  Run from any workspace directory. Settings are saved per-workspace in
  .firesim-lab.env so you never have to re-enter them.

  $(_bold "Usage:")
    $(_cyan "cd ~/my-workspace")
    $(_cyan "firesim-lab")                  # start container (or enter if running)
    $(_cyan "firesim-lab --down")           # stop the container
    $(_cyan "firesim-lab --pull")           # pull latest image and restart
    $(_cyan "firesim-lab --reconfigure")    # re-prompt all settings
    $(_cyan "firesim-lab --status")         # show container status
    $(_cyan "firesim-lab --clean-cache")    # remove SBT/ccache volumes
    $(_cyan "firesim-lab --help")           # show this message

  $(_bold "Non-interactive (env vars override prompts):")
    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab

  $(_bold "Workspace layout:")
    <workspace>/                    → mounted as /target inside the container
    └── <project>/                  → auto-detected firesim-lab project
        ├── build.sbt
        ├── env.sh
        └── ...

  $(_bold "Settings file:") .firesim-lab.env  (written to each workspace directory)

USAGE
}

# ── Parse arguments ───────────────────────────────────────────────────────────
DO_DOWN=0
DO_PULL=0
DO_CLEAN_CACHE=0
DO_RECONFIGURE=0
DO_STATUS=0

for arg in "$@"; do
  case "$arg" in
    -h|--help)      usage; exit 0 ;;
    --down)         DO_DOWN=1 ;;
    --pull)         DO_PULL=1 ;;
    --clean-cache)  DO_CLEAN_CACHE=1 ;;
    --reconfigure)  DO_RECONFIGURE=1 ;;
    --status)       DO_STATUS=1 ;;
    *)
      echo "$(_red "Unknown option:") $arg"
      usage
      exit 1
      ;;
  esac
done

# ── Detect docker compose command ─────────────────────────────────────────────
if docker compose version &>/dev/null 2>&1; then
  COMPOSE="docker compose"
elif command -v docker-compose &>/dev/null; then
  COMPOSE="docker-compose"
else
  echo "$(_red "Error:") Neither 'docker compose' nor 'docker-compose' found."
  echo "Install Docker Desktop (macOS/Windows) or docker-compose-plugin (Linux)."
  exit 1
fi

# ── Ensure docker-compose.yaml is present in install dir ─────────────────────
if [[ ! -f "$COMPOSE_FILE" ]]; then
  echo "$(_cyan "→ Downloading docker-compose.yaml...")"
  if command -v curl &>/dev/null; then
    curl -fsSL "$COMPOSE_URL" -o "$COMPOSE_FILE"
  elif command -v wget &>/dev/null; then
    wget -qO "$COMPOSE_FILE" "$COMPOSE_URL"
  else
    echo "$(_red "Error:") curl or wget required to download docker-compose.yaml"
    exit 1
  fi
  echo "$(_green "✓") docker-compose.yaml downloaded to $INSTALL_DIR"
fi

# ── Shared compose invocation (always uses workspace .env) ───────────────────
_compose() {
  $COMPOSE --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

# ── Handle --clean-cache ──────────────────────────────────────────────────────
if [[ $DO_CLEAN_CACHE -eq 1 ]]; then
  echo "$(_yellow "⚠  Removing all named SBT and ccache volumes...")"
  docker volume rm \
    firesim-lab-sbt-ivy \
    firesim-lab-sbt-coursier \
    firesim-lab-sbt-boot \
    firesim-lab-sbt-global \
    firesim-lab-verilator-ccache \
    2>/dev/null || true
  echo "$(_green "✓") Cache volumes removed. They will be re-seeded on next start."
  exit 0
fi

# ── Handle --status ───────────────────────────────────────────────────────────
if [[ $DO_STATUS -eq 1 ]]; then
  echo ""
  echo "  $(_bold "Workspace") : $WORKSPACE_DIR"
  echo "  $(_bold "Container") : $CONTAINER_NAME"
  echo ""
  docker ps -a --filter "name=^/${CONTAINER_NAME}$" \
    --format "  Status    : {{.Status}}\n  Image     : {{.Image}}\n  Created   : {{.RunningFor}}" \
    || echo "  $(_yellow "(no container found)")"
  echo ""
  exit 0
fi

# ── Handle --down ─────────────────────────────────────────────────────────────
if [[ $DO_DOWN -eq 1 ]]; then
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$(_red "Error:") No .firesim-lab.env found in $WORKSPACE_DIR"
    echo "Nothing to stop."
    exit 1
  fi
  echo "$(_cyan "→ Stopping container:") $CONTAINER_NAME"
  _compose down
  echo "$(_green "✓") Container stopped."
  exit 0
fi

# ── Banner ────────────────────────────────────────────────────────────────────
echo ""
echo "  $(_bold "firesim-lab") — workspace: $(_cyan "$WORKSPACE_DIR")"
echo "  ─────────────────────────────────────────────────────────"
echo ""

# ── Auto-detect firesim-lab project(s) in workspace ──────────────────────────
# A firesim-lab project is identified by a build.sbt in a first-level
# subdirectory that contains "FIRESIM_LAB_ROOT" — a string unique to projects
# generated by new-target.py and not expected in unrelated SBT projects.
_detect_projects() {
  local dir sbt
  for dir in "$WORKSPACE_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    sbt="${dir}build.sbt"
    if [[ -f "$sbt" ]] && grep -q "FIRESIM_LAB_ROOT" "$sbt"; then
      basename "$dir"
    fi
  done
}

echo "$(_cyan "→ Scanning workspace for firesim-lab projects...")"

mapfile -t DETECTED < <(_detect_projects)

PROJECT_NAME=""   # empty = new workspace / no project selected

if [[ ${#DETECTED[@]} -eq 0 ]]; then
  # ── No project found ─────────────────────────────────────────────────────────
  echo "  $(_yellow "ℹ  No firesim-lab project detected.")"
  echo "     Scaffold one with new-target.py once the container is running."

elif [[ ${#DETECTED[@]} -eq 1 ]]; then
  # ── Exactly one project — confirm with user ───────────────────────────────────
  echo "  $(_green "✓") Detected project: $(_bold "${DETECTED[0]}")"
  read -p "     Use this project? [Y/n]: " yn
  yn="${yn:-Y}"
  if [[ "$yn" =~ ^[Yy]$ ]]; then
    PROJECT_NAME="${DETECTED[0]}"
  else
    echo "  $(_yellow "ℹ  Skipping detected project — no project will be active.")"
  fi

else
  # ── Multiple projects — warn and ask user to pick ─────────────────────────────
  echo "  $(_yellow "⚠  Multiple firesim-lab projects detected.")"
  echo "     Only one project per workspace is supported."
  echo ""
  local i=1
  for name in "${DETECTED[@]}"; do
    echo "     $i) $name"
    (( i++ ))
  done
  echo ""
  while true; do
    read -p "     Enter the project name to use: " PROJECT_NAME
    local valid=0
    for name in "${DETECTED[@]}"; do
      [[ "$name" == "$PROJECT_NAME" ]] && valid=1 && break
    done
    if [[ $valid -eq 1 ]]; then
      echo "  $(_green "✓") Using project: $PROJECT_NAME"
      break
    else
      echo "  $(_red "✗") '$PROJECT_NAME' is not one of the detected projects. Try again."
    fi
  done
fi

echo ""

# ── Load existing .env or collect settings ────────────────────────────────────
_env_loaded=0
if [[ -f "$ENV_FILE" && $DO_RECONFIGURE -eq 0 ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  _env_loaded=1
  echo "  $(_green "✓") Loaded settings from .firesim-lab.env"
  echo "      Image : $FIRESIM_IMAGE   Threads : $VERILATOR_THREADS"
  echo ""
fi

if [[ $_env_loaded -eq 0 || $DO_RECONFIGURE -eq 1 ]]; then
  # ── Docker image ──────────────────────────────────────────────────────────────
  if [[ -z "${FIRESIM_IMAGE:-}" ]]; then
    read -e -p "  $(_bold "Docker image name:tag") [$DEFAULT_IMAGE]: " FIRESIM_IMAGE
  fi
  FIRESIM_IMAGE="${FIRESIM_IMAGE:-$DEFAULT_IMAGE}"

  # ── Verilator threads ─────────────────────────────────────────────────────────
  if [[ -z "${VERILATOR_THREADS:-}" ]]; then
    read -e -p "  $(_bold "Verilator parallel jobs") [$DEFAULT_VERILATOR_THREADS]: " VERILATOR_THREADS
  fi
  VERILATOR_THREADS="${VERILATOR_THREADS:-$DEFAULT_VERILATOR_THREADS}"

  # ── Memory limits (not prompted — override via env var if needed) ─────────────
  CONTAINER_MEMORY_LIMIT="${CONTAINER_MEMORY_LIMIT:-$DEFAULT_MEMORY_LIMIT}"
  CONTAINER_MEMORY_RESERVE="${CONTAINER_MEMORY_RESERVE:-$DEFAULT_MEMORY_RESERVE}"

  echo ""
fi

# ── Host user identity ────────────────────────────────────────────────────────
HOST_UID=$(id -u)
HOST_GID=$(id -g)

# ── Write .firesim-lab.env into the workspace ─────────────────────────────────
echo "$(_cyan "→ Writing settings to $ENV_FILE...")"

cat > "$ENV_FILE" <<ENV
# ===========================================================================
# .firesim-lab.env — workspace settings for firesim-lab
# Workspace : $WORKSPACE_DIR
# Generated : $(date "+%Y-%m-%d %H:%M")
#
# This file is workspace-specific. Do not copy it between workspaces.
# Run 'firesim-lab --reconfigure' to update these settings.
# ===========================================================================

# ── Docker image and container ──────────────────────────────────────────────
FIRESIM_IMAGE=${FIRESIM_IMAGE}
CONTAINER_NAME=${CONTAINER_NAME}

# ── Workspace ───────────────────────────────────────────────────────────────
# Mounted as /target inside the container.
# All subdirectories (projects, build outputs) are persisted automatically.
HOST_WORKSPACE_DIR=${WORKSPACE_DIR}

# ── Host user mapping ───────────────────────────────────────────────────────
HOST_UID=${HOST_UID}
HOST_GID=${HOST_GID}

# ── Performance tuning ──────────────────────────────────────────────────────
VERILATOR_THREADS=${VERILATOR_THREADS}
CONTAINER_MEMORY_LIMIT=${CONTAINER_MEMORY_LIMIT}
CONTAINER_MEMORY_RESERVE=${CONTAINER_MEMORY_RESERVE}
ENV

echo "  $(_green "✓") Settings saved"
echo ""

# ── Summary ───────────────────────────────────────────────────────────────────
echo "  $(_bold "Configuration")"
echo "  ─────────────────────────────────────────────────────────"
echo "  Image          : $(_cyan "$FIRESIM_IMAGE")"
echo "  Container      : $CONTAINER_NAME"
echo "  Workspace      : $WORKSPACE_DIR  →  /target"
if [[ -n "$PROJECT_NAME" ]]; then
echo "  Project        : $PROJECT_NAME   →  /target/$PROJECT_NAME"
fi
echo "  Verilator jobs : $VERILATOR_THREADS"
echo "  Memory limit   : $CONTAINER_MEMORY_LIMIT (reserve: $CONTAINER_MEMORY_RESERVE)"
echo "  ─────────────────────────────────────────────────────────"
echo ""

# ── Image check / pull ────────────────────────────────────────────────────────
echo "$(_cyan "→ Checking Docker image: $FIRESIM_IMAGE...")"

_try_pull() {
  echo "  $(_cyan "→ Pulling $FIRESIM_IMAGE...")"
  if docker pull "$FIRESIM_IMAGE" 2>/dev/null || true; then
    if docker image inspect "$FIRESIM_IMAGE" &>/dev/null; then
      echo "  $(_green "✓") Image pulled successfully."
    else
      echo "  $(_yellow "⚠  Pull failed — docker-compose will attempt a local build.")"
    fi
  fi
}

if ! docker image inspect "$FIRESIM_IMAGE" &>/dev/null; then
  echo "  $(_yellow "⚠  Image not found locally.")"
  if [[ $DO_PULL -eq 1 ]]; then
    _try_pull
  else
    read -p "     Pull it now? [Y/n]: " yn
    yn="${yn:-Y}"
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      _try_pull
    else
      echo "  $(_yellow "⚠  Skipping pull — will attempt local build if needed.")"
    fi
  fi
else
  echo "  $(_green "✓") Image found locally: $FIRESIM_IMAGE"
  [[ $DO_PULL -eq 1 ]] && _try_pull
fi

echo ""

# ── Container lifecycle ───────────────────────────────────────────────────────
_container_running() {
  docker ps --filter "name=^/${CONTAINER_NAME}$" --filter "status=running" -q \
    | grep -q .
}

_container_exists() {
  docker ps -a --filter "name=^/${CONTAINER_NAME}$" -q \
    | grep -q .
}

_wait_for_container() {
  local max_wait=60
  local waited=0
  echo -n "  $(_cyan "→ Waiting for container to be ready")"
  while ! _container_running; do
    if [[ $waited -ge $max_wait ]]; then
      echo ""
      echo "  $(_red "✗ Container did not start within ${max_wait}s.")"
      echo "  Check logs: docker logs $CONTAINER_NAME"
      exit 1
    fi
    echo -n "."
    sleep 1
    (( waited++ ))
  done
  echo " $(_green "ready")"
}

if _container_running; then
  echo "  $(_green "✓") Container already running — entering shell..."
  echo ""
  docker exec -it "$CONTAINER_NAME" bash
  exit 0
fi

if _container_exists; then
  echo "  $(_yellow "⚠  Container exists but is stopped — restarting...")"
  docker start "$CONTAINER_NAME"
else
  echo "$(_cyan "→ Starting container...")"
  _compose up -d
fi

_wait_for_container

echo ""
echo "  $(_green "✓  Container '$CONTAINER_NAME' is running.")"
echo ""

# ── Post-start instructions ───────────────────────────────────────────────────
# Use the detected/confirmed project name, or a placeholder for new workspaces.
_project="${PROJECT_NAME:-<my-project>}"

if [[ -z "$PROJECT_NAME" ]]; then
  # New workspace — no project scaffolded yet
  echo "  $(_yellow "ℹ  No firesim-lab project found in this workspace.")"
  echo "  $(_bold "Scaffold a new project inside the container:")"
  echo ""
  echo "    $(_cyan "python3 \$FIRESIM_LAB_ROOT/scripts/new-target.py \\")  "
  echo "    $(_cyan "    --name $_project \\")  "
  echo "    $(_cyan "    --output-dir /target \\")  "
  echo "    $(_cyan "    --bridge uart,fased \\")  "
  echo "    $(_cyan "    --feature verilog-blackbox")  "
  echo ""
  echo "  Run $(_cyan "python3 \$FIRESIM_LAB_ROOT/scripts/new-target.py --list") to see"
  echo "  all available bridges and features."
  echo ""
  echo "  $(_yellow "Tip:") After scaffolding, re-run $(_cyan "firesim-lab") from this workspace"
  echo "  to have the project auto-detected on future launches."

elif [[ ! -f "$WORKSPACE_DIR/$PROJECT_NAME/Makefile" ]]; then
  # Project directory exists (has build.sbt) but scaffold is incomplete
  echo "  $(_yellow "⚠  Project '$PROJECT_NAME' has not been fully scaffolded yet.")"
  echo "  $(_bold "Complete it inside the container:")"
  echo ""
  echo "    $(_cyan "python3 \$FIRESIM_LAB_ROOT/scripts/new-target.py \\")  "
  echo "    $(_cyan "    --name $_project \\")  "
  echo "    $(_cyan "    --output-dir /target \\")  "
  echo "    $(_cyan "    --bridge uart,fased \\")  "
  echo "    $(_cyan "    --feature verilog-blackbox")  "
  echo ""

else
  # Fully scaffolded project — show build commands
  echo "  $(_bold "Build and run your target:")"
  echo "    cd /target/$PROJECT_NAME"
  echo "    source env.sh"
  echo "    make elaborate && make verilator && make run"
fi

echo ""
echo "  $(_bold "Opening shell — 'exit' leaves the shell but keeps the container running.")"
echo "  $(_bold "To stop the container:") firesim-lab --down"
echo ""

docker exec -it "$CONTAINER_NAME" bash
