#!/usr/bin/env bash
# =============================================================================
#  firesim-lab — simulation environment launcher
#
#  Installed once to ~/.firesim-lab/docker/ and symlinked into your PATH by
#  install.sh.  Run from any workspace directory.
#
#  On first run in a new directory (no .firesim-lab.env):
#    Auto-detects any existing firesim-lab project in the workspace.
#    Prompts for image/thread settings, writes .firesim-lab.env, starts the
#    container, and drops you into a shell.
#
#  On subsequent runs (.firesim-lab.env already exists):
#    Reads saved settings silently, starts or enters the container.
#
#  Usage:
#    cd ~/my-workspace && firesim-lab                  # start / enter
#    cd ~/my-workspace && firesim-lab --down           # stop container
#    cd ~/my-workspace && firesim-lab --pull           # pull fresh image
#    cd ~/my-workspace && firesim-lab --reconfigure    # re-prompt settings
#    cd ~/my-workspace && firesim-lab --status         # show container info
#    cd ~/my-workspace && firesim-lab --clean-cache    # wipe SBT/ccache volumes
#
#  Non-interactive (CI / scripted):
#    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab
# =============================================================================

set -euo pipefail

# ── Pipe-detection guard ──────────────────────────────────────────────────────
_first_arg="${1:-}"
_non_interactive_safe=0
case "$_first_arg" in
  -h|--help|--down|--pull|--clean-cache|--status|--upgrade) _non_interactive_safe=1 ;;
esac

if [[ ! -t 0 && $_non_interactive_safe -eq 0 ]]; then
  cat >&2 <<PIPE_ERR

  ERROR: firesim-lab cannot be piped directly.

  It uses interactive prompts and must be run from a local installation.
  The correct entry point is install.sh:

    curl -sSL https://raw.githubusercontent.com/pentarisc/firesim-lab/main/docker/install.sh | bash

PIPE_ERR
  exit 1
fi

# ── Locate installation directory ─────────────────────────────────────────────
# Resolve symlinks so INSTALL_DIR always points to the real installation folder
# even when invoked through a PATH symlink.
_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" && pwd
}
INSTALL_DIR="$(_resolve_script_dir)"

# AWS config directory — created by install.sh, bind-mounted into the container
# as ~/.aws.  Path is anchored to the install directory so it follows custom
# INSTALL_DIR values (e.g. /opt/firesim-lab) and never collides with the host's
# own ~/.aws.  The launcher ensures the directory exists with mode 700 in case
# it was removed or the user is upgrading from a version that did not create it.
HOST_AWS_DIR="${INSTALL_DIR}/.aws"
if [[ ! -d "$HOST_AWS_DIR" ]]; then
  mkdir -p "$HOST_AWS_DIR"
  chmod 700 "$HOST_AWS_DIR"
fi

# SSH key directory — created by install.sh, bind-mounted into the container
# as ~/.ssh.  Same anchoring strategy as HOST_AWS_DIR: lives under the install
# directory so it follows custom INSTALL_DIR values and never collides with
# the host's own ~/.ssh.  Mode 700 is required by OpenSSH; individual private
# keys placed here must be chmod 600.  Created defensively here in case the
# user is upgrading from a version that did not create it.
HOST_SSH_DIR="${INSTALL_DIR}/.ssh"
if [[ ! -d "$HOST_SSH_DIR" ]]; then
  mkdir -p "$HOST_SSH_DIR"
  chmod 700 "$HOST_SSH_DIR"
fi

# ── Workspace is always the current working directory ─────────────────────────
WORKSPACE_DIR="$(pwd)"
WORKSPACE_BASENAME="$(basename "$WORKSPACE_DIR")"
ENV_FILE="$WORKSPACE_DIR/.firesim-lab.env"

# ── Explicit image override (CI / advanced) ──────────────────────────────────
# Captured before the installed manifest is sourced below (the manifest also
# sets FIRESIM_IMAGE).  A non-empty value here means the caller deliberately
# pinned an image via the environment; it wins over the workspace/manifest pin
# and bypasses the version-skew gate.
_IMAGE_OVERRIDE="${FIRESIM_IMAGE:-}"

# ── Installed manifest ────────────────────────────────────────────────────────
# Written by install.sh.  Pins the firesim-lab version, git ref, and Docker
# image this installation was set up for.  New workspaces inherit these values;
# existing workspaces are checked against INSTALLED_VERSION for skew.
MANIFEST_FILE="$INSTALL_DIR/.firesim-lab-installed"
INSTALLED_VERSION=""
INSTALLED_REF="main"
INSTALLED_IMAGE=""
if [[ -f "$MANIFEST_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$MANIFEST_FILE"
  set +a
  INSTALLED_VERSION="${FIRESIM_LAB_VERSION:-}"
  INSTALLED_REF="${FIRESIM_LAB_REF:-main}"
  INSTALLED_IMAGE="${FIRESIM_IMAGE:-}"
  # Drop the manifest-sourced values so they cannot masquerade as a workspace
  # pin (FIRESIM_LAB_VERSION) or an explicit override (FIRESIM_IMAGE) later.
  unset FIRESIM_IMAGE FIRESIM_LAB_VERSION
fi

# ── Static configuration ──────────────────────────────────────────────────────
# REPO_RAW tracks the installed ref so any version-correct re-fetch (e.g. the
# compose file below) stays pinned instead of silently pulling from `main`.
REPO_RAW="https://raw.githubusercontent.com/pentarisc/firesim-lab/${INSTALLED_REF}"
COMPOSE_URL="${REPO_RAW}/docker/docker-compose.yaml"
COMPOSE_FILE="$INSTALL_DIR/docker-compose.yaml"

# Default image for new workspaces: the installed image from the manifest,
# falling back to :latest only when no manifest is present (legacy install).
DEFAULT_IMAGE="${INSTALLED_IMAGE:-pentarisc/firesim-lab:latest}"
DEFAULT_VERILATOR_THREADS=$(sysctl -n hw.logicalcpu 2>/dev/null || nproc 2>/dev/null || echo 4)
DEFAULT_MEMORY_LIMIT="16g"
DEFAULT_MEMORY_RESERVE="8g"
# GID of the firesim-lab-cache group baked into the Docker image.
# All cache directories are group-owned by this GID with permissions 2775.
# Only change this if 2543 conflicts with an existing group on your host AND
# you are rebuilding the image locally with a matching CACHE_GID build arg.
DEFAULT_CACHE_GID=2543

# Container name is workspace-scoped only — one container per workspace.
# Illegal docker name characters are replaced with '-'.
CONTAINER_NAME="firesim-lab-$(echo "$WORKSPACE_BASENAME" | tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/-*$//')"

# ── Colour helpers ────────────────────────────────────────────────────────────
_bold()  { printf '\033[1m%s\033[0m' "$*"; }
_green() { printf '\033[32m%s\033[0m' "$*"; }
_cyan()  { printf '\033[36m%s\033[0m' "$*"; }
_yellow(){ printf '\033[33m%s\033[0m' "$*"; }
_red()   { printf '\033[31m%s\033[0m' "$*"; }

# ── Help ──────────────────────────────────────────────────────────────────────
usage() {
  cat <<USAGE

  $(_bold "firesim-lab") — FireSim standalone simulation environment

  Run from any workspace directory. Settings are saved per-workspace in
  .firesim-lab.env so you never have to re-enter them.

  $(_bold "Usage:")
    $(_cyan "cd ~/my-workspace")
    $(_cyan "firesim-lab")                  # start container (or enter if running)
    $(_cyan "firesim-lab --down")           # stop the container
    $(_cyan "firesim-lab --pull")           # pull latest image and restart
    $(_cyan "firesim-lab --reconfigure")    # re-prompt all settings
    $(_cyan "firesim-lab --upgrade")        # re-pin workspace to installed version
    $(_cyan "firesim-lab --status")         # show container status
    $(_cyan "firesim-lab --clean-cache")    # remove SBT/ccache volumes
    $(_cyan "firesim-lab --help")           # show this message

  $(_bold "Non-interactive (env vars override prompts):")
    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab

  $(_bold "Workspace layout:")
    <workspace>/                    → mounted as /target inside the container
    └── <project>/                  → auto-detected firesim-lab project
        ├── build.sbt
        ├── env.sh
        └── ...

  $(_bold "Settings file:") .firesim-lab.env  (written to each workspace directory)

USAGE
}

# ── Parse arguments ───────────────────────────────────────────────────────────
DO_DOWN=0
DO_PULL=0
DO_CLEAN_CACHE=0
DO_RECONFIGURE=0
DO_STATUS=0
DO_UPGRADE=0

for arg in "$@"; do
  case "$arg" in
    -h|--help)      usage; exit 0 ;;
    --down)         DO_DOWN=1 ;;
    --pull)         DO_PULL=1 ;;
    --clean-cache)  DO_CLEAN_CACHE=1 ;;
    --reconfigure)  DO_RECONFIGURE=1 ;;
    --status)       DO_STATUS=1 ;;
    --upgrade)      DO_UPGRADE=1 ;;
    *)
      echo "$(_red "Unknown option:") $arg"
      usage
      exit 1
      ;;
  esac
done

# ── Detect docker compose command ─────────────────────────────────────────────
if docker compose version &>/dev/null 2>&1; then
  COMPOSE="docker compose"
elif command -v docker-compose &>/dev/null; then
  COMPOSE="docker-compose"
else
  echo "$(_red "Error:") Neither 'docker compose' nor 'docker-compose' found."
  echo "Install Docker Desktop (macOS/Windows) or docker-compose-plugin (Linux)."
  exit 1
fi

# ── Ensure docker-compose.yaml is present in install dir ─────────────────────
if [[ ! -f "$COMPOSE_FILE" ]]; then
  echo "$(_cyan "→ Downloading docker-compose.yaml...")"
  if command -v curl &>/dev/null; then
    curl -fsSL "$COMPOSE_URL" -o "$COMPOSE_FILE"
  elif command -v wget &>/dev/null; then
    wget -qO "$COMPOSE_FILE" "$COMPOSE_URL"
  else
    echo "$(_red "Error:") curl or wget required to download docker-compose.yaml"
    exit 1
  fi
  echo "$(_green "✓") docker-compose.yaml downloaded to $INSTALL_DIR"
fi

# ── Shared compose invocation (always uses workspace .env) ───────────────────
_compose() {
  $COMPOSE -p "$CONTAINER_NAME" --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

# ── Handle --clean-cache ──────────────────────────────────────────────────────
if [[ $DO_CLEAN_CACHE -eq 1 ]]; then
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$(_red "Error:") No .firesim-lab.env found in $WORKSPACE_DIR"
    echo "Nothing to clean."
    exit 1
  fi
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  echo "$(_yellow "⚠  Removing SBT and ccache volumes for UID ${HOST_UID}...")"
  docker volume rm \
    "${VOLUME_SBT_IVY}" \
    "${VOLUME_SBT_COURSIER}" \
    "${VOLUME_SBT_BOOT}" \
    "${VOLUME_SBT_GLOBAL}" \
    "${VOLUME_CCACHE}" \
    2>/dev/null || true
  echo "$(_green "✓") Cache volumes removed. They will be re-seeded on next start."
  exit 0
fi

# ── Handle --status ───────────────────────────────────────────────────────────
if [[ $DO_STATUS -eq 1 ]]; then
  echo ""
  echo "  $(_bold "Workspace") : $WORKSPACE_DIR"
  echo "  $(_bold "Container") : $CONTAINER_NAME"
  echo ""
  docker ps -a --filter "name=^/${CONTAINER_NAME}$" \
    --format "  Status    : {{.Status}}\n  Image     : {{.Image}}\n  Created   : {{.RunningFor}}" \
    || echo "  $(_yellow "(no container found)")"
  echo ""
  exit 0
fi

# ── Handle --down ─────────────────────────────────────────────────────────────
if [[ $DO_DOWN -eq 1 ]]; then
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$(_red "Error:") No .firesim-lab.env found in $WORKSPACE_DIR"
    echo "Nothing to stop."
    exit 1
  fi
  echo "$(_cyan "→ Stopping container:") $CONTAINER_NAME"
  _compose down
  echo "$(_green "✓") Container stopped."
  exit 0
fi

# ── Version-skew gate (fail fast, before any prompt or output) ────────────────
# A workspace is pinned to the firesim-lab version that created it.  Reject a
# mismatched workspace up front — before the banner, project detection, or
# loading settings — so the user is never asked to pick a project or shown stale
# settings for a workspace that cannot run.  The host launcher/compose and the
# container image are a matched set; host↔container backward compatibility is
# not guaranteed.  Skipped for --upgrade/--reconfigure (which re-pin
# deliberately) and when an explicit FIRESIM_IMAGE override is set.  Only the
# version line is read here; the full settings load happens later.
if [[ -f "$ENV_FILE" && $DO_UPGRADE -eq 0 && $DO_RECONFIGURE -eq 0 \
      && -z "$_IMAGE_OVERRIDE" && -n "$INSTALLED_VERSION" ]]; then
  _ws_version="$(sed -n 's/^[[:space:]]*FIRESIM_LAB_VERSION=//p' "$ENV_FILE" | tail -n1)"
  _ws_version="${_ws_version%\"}"; _ws_version="${_ws_version#\"}"   # strip optional quotes
  if [[ "${_ws_version:-}" != "$INSTALLED_VERSION" ]]; then
    echo ""
    echo "  $(_red "✗ firesim-lab version mismatch.")"
    echo ""
    echo "     This workspace is pinned to : $(_bold "${_ws_version:-<unknown / legacy>}")"
    echo "     Installed version is        : $(_bold "${INSTALLED_VERSION}")"
    echo ""
    echo "     The host scripts and the container image must match.  Choose one:"
    echo ""
    echo "       $(_cyan "firesim-lab --upgrade")   migrate this workspace to ${INSTALLED_VERSION}"
    echo "                              (re-pins the image; preserves your other settings)"
    echo ""
    if [[ -n "$_ws_version" ]]; then
    echo "       or reinstall the matching version to keep this workspace unchanged:"
    echo "       $(_cyan "curl -sSL https://raw.githubusercontent.com/pentarisc/firesim-lab/main/docker/install.sh | bash -s -- v${_ws_version}")"
    echo ""
    fi
    exit 1
  fi
fi

# ── Banner ────────────────────────────────────────────────────────────────────
echo ""
echo "  $(_bold "firesim-lab") — workspace: $(_cyan "$WORKSPACE_DIR")"
echo "  ─────────────────────────────────────────────────────────"
echo ""

# ── Auto-detect firesim-lab project(s) in workspace ──────────────────────────
# A firesim-lab project is identified by a build.sbt in a first-level
# subdirectory that contains "FIRESIM_LAB_ROOT" — a string unique to projects
# generated by init-target and not expected in unrelated SBT projects.
_detect_projects() {
  local dir sbt
  for dir in "$WORKSPACE_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    sbt="${dir}build.sbt"
    if [[ -f "$sbt" ]] && grep -q "FIRESIM_LAB_ROOT" "$sbt"; then
      basename "$dir"
    fi
  done
}

echo "$(_cyan "→ Scanning workspace for firesim-lab projects...")"

DETECTED=()
while IFS= read -r _line; do
  [[ -n "$_line" ]] && DETECTED+=("$_line")
done < <(_detect_projects)

PROJECT_NAME=""   # empty = new workspace / no project selected

if [[ ${#DETECTED[@]} -eq 0 ]]; then
  # ── No project found ─────────────────────────────────────────────────────────
  echo "  $(_yellow "ℹ  No firesim-lab project detected.")"
  echo "     Scaffold one with init-target once the container is running."

elif [[ ${#DETECTED[@]} -eq 1 ]]; then
  # ── Exactly one project — confirm with user ───────────────────────────────────
  echo "  $(_green "✓") Detected project: $(_bold "${DETECTED[0]}")"
  read -p "     Use this project? [Y/n]: " yn
  yn="${yn:-Y}"
  if [[ "$yn" =~ ^[Yy]$ ]]; then
    PROJECT_NAME="${DETECTED[0]}"
  else
    echo "  $(_yellow "ℹ  Skipping detected project — no project will be active.")"
  fi

else
  # ── Multiple projects — warn and ask user to pick ─────────────────────────────
  echo "  $(_yellow "⚠  Multiple firesim-lab projects detected.")"
  echo "     Only one project per workspace is supported."
  echo ""
  i=1
  for name in "${DETECTED[@]}"; do
    echo "     $i) $name"
    (( i++ ))
  done
  echo ""
  while true; do
    read -p "     Enter the project name to use: " PROJECT_NAME
    valid=0
    for name in "${DETECTED[@]}"; do
      [[ "$name" == "$PROJECT_NAME" ]] && valid=1 && break
    done
    if [[ $valid -eq 1 ]]; then
      echo "  $(_green "✓") Using project: $PROJECT_NAME"
      break
    else
      echo "  $(_red "✗") '$PROJECT_NAME' is not one of the detected projects. Try again."
    fi
  done
fi

echo ""

# ── Load existing .env or collect settings ────────────────────────────────────
_env_loaded=0
if [[ -f "$ENV_FILE" && $DO_RECONFIGURE -eq 0 ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  _env_loaded=1
  echo "  $(_green "✓") Loaded settings from .firesim-lab.env"
  echo "      Image : $FIRESIM_IMAGE   Threads : $VERILATOR_THREADS"
  echo ""
fi

# The version this workspace was pinned to (empty for legacy env files written
# before version pinning existed).
WORKSPACE_VERSION="${FIRESIM_LAB_VERSION:-}"

# An explicit FIRESIM_IMAGE env override always wins over the workspace pin.
if [[ -n "$_IMAGE_OVERRIDE" ]]; then
  FIRESIM_IMAGE="$_IMAGE_OVERRIDE"
fi

# (The version-skew gate runs earlier, before the banner — see above. By this
# point a mismatched workspace has already been rejected, unless this is an
# --upgrade/--reconfigure or an explicit FIRESIM_IMAGE override.)

# ── Handle --upgrade ──────────────────────────────────────────────────────────
# Re-pin this workspace's image + version to the installed manifest, preserving
# all other settings (threads, memory, plugins, volumes, UID mapping).
if [[ $DO_UPGRADE -eq 1 ]]; then
  if [[ $_env_loaded -eq 0 ]]; then
    echo "$(_red "Error:") No .firesim-lab.env found in $WORKSPACE_DIR — nothing to upgrade."
    echo "Run 'firesim-lab' here first to create the workspace."
    exit 1
  fi
  if [[ -z "$INSTALLED_IMAGE" || -z "$INSTALLED_VERSION" ]]; then
    echo "$(_red "Error:") No installed manifest found ($MANIFEST_FILE)."
    echo "Reinstall firesim-lab so the installed version is recorded, then retry."
    exit 1
  fi
  if [[ "$WORKSPACE_VERSION" == "$INSTALLED_VERSION" ]]; then
    echo "  $(_green "✓") Workspace already at the installed version ($INSTALLED_VERSION). Nothing to upgrade."
    exit 0
  fi
  echo "  $(_yellow "⚠  Upgrading workspace pin:")"
  echo "       version : ${WORKSPACE_VERSION:-<unknown>}  →  ${INSTALLED_VERSION}"
  echo "       image   : ${FIRESIM_IMAGE:-<unknown>}  →  ${INSTALLED_IMAGE}"
  echo ""
  echo "  $(_yellow "Note:") if the SBT/Scala toolchain changed between versions, run"
  echo "        $(_cyan "firesim-lab --clean-cache") afterwards to re-seed the build caches."
  echo ""
  read -p "     Proceed? [Y/n]: " yn
  yn="${yn:-Y}"
  if [[ ! "$yn" =~ ^[Yy]$ ]]; then
    echo "  $(_yellow "Aborted — workspace left unchanged.")"
    exit 0
  fi
  FIRESIM_IMAGE="$INSTALLED_IMAGE"
  FIRESIM_LAB_VERSION="$INSTALLED_VERSION"
  WORKSPACE_VERSION="$INSTALLED_VERSION"

  # Remove any existing container so the lifecycle below recreates it on the
  # newly-pinned image — a running or stopped container still uses the old one.
  if docker ps -a --filter "name=^/${CONTAINER_NAME}$" -q | grep -q .; then
    echo "  $(_cyan "→ Removing old container so it is recreated on the new image...")"
    docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
  fi
  echo ""
fi

if [[ $_env_loaded -eq 0 || $DO_RECONFIGURE -eq 1 ]]; then
  # ── Docker image + version (pinned, not prompted) ─────────────────────────────
  # New workspaces inherit the installed image/version from the manifest.  An
  # explicit FIRESIM_IMAGE override (captured earlier) takes precedence.  The
  # image is never prompted for: it is a matched pair with the host scripts.
  FIRESIM_IMAGE="${_IMAGE_OVERRIDE:-$DEFAULT_IMAGE}"
  FIRESIM_LAB_VERSION="${INSTALLED_VERSION:-${FIRESIM_LAB_VERSION:-unknown}}"

  # ── Verilator threads ─────────────────────────────────────────────────────────
  if [[ -z "${VERILATOR_THREADS:-}" ]]; then
    read -e -p "  $(_bold "Verilator parallel jobs") [$DEFAULT_VERILATOR_THREADS]: " VERILATOR_THREADS
  fi
  VERILATOR_THREADS="${VERILATOR_THREADS:-$DEFAULT_VERILATOR_THREADS}"

  # ── Custom plugins ─────────────────────────────────────────────────────────
  # allow_plugins is initialised here so the test below is safe under `set -u`
  # even when ENABLE_CUSTOM_PLUGINS is already set and the inner read is skipped.
  allow_plugins=""
  if [[ -z "${ENABLE_CUSTOM_PLUGINS:-}" ]]; then
    read -e -p "  $(_bold "Enable custom Python plugins (Security Risk)? [y/N]:") [n]: " allow_plugins
  fi
  if [[ "$allow_plugins" =~ ^[Yy]$ ]]; then
    ENABLE_CUSTOM_PLUGINS=1
  else
    ENABLE_CUSTOM_PLUGINS=0
  fi

  # ── Cache group ID ────────────────────────────────────────────────────────────
  # Not prompted.  Must match the CACHE_GID ARG baked into the image (default
  # 2543).  Override only if rebuilding the image locally with a custom GID.
  CACHE_GID="${CACHE_GID:-$DEFAULT_CACHE_GID}"

  # ── Memory limits (not prompted — override via env var if needed) ─────────────
  CONTAINER_MEMORY_LIMIT="${CONTAINER_MEMORY_LIMIT:-$DEFAULT_MEMORY_LIMIT}"
  CONTAINER_MEMORY_RESERVE="${CONTAINER_MEMORY_RESERVE:-$DEFAULT_MEMORY_RESERVE}"

  echo ""
fi

# ── Host user identity ────────────────────────────────────────────────────────
HOST_UID=$(id -u)
HOST_GID=$(id -g)

# ── CACHE_GID host conflict check ─────────────────────────────────────────────
# GID 2543 (firesim-lab-cache) is used inside the container to grant write
# access to pre-warmed cache directories.  It never leaks to the host, so a
# collision is harmless in practice — we warn rather than abort.
CACHE_GID="${CACHE_GID:-$DEFAULT_CACHE_GID}"
if command -v getent >/dev/null 2>&1; then
  _conflicting_group=$(getent group "${CACHE_GID}" 2>/dev/null | cut -d: -f1 || true)
else
  _conflicting_group=""
fi
if [[ -n "$_conflicting_group" ]]; then
  echo "  $(_yellow "⚠  Host GID ${CACHE_GID} is already used by group '${_conflicting_group}'.")"
  echo "     The container uses this GID internally for cache directory access."
  echo "     This is normally harmless.  If you see unexpected permission errors,"
  echo "     rebuild the image with a different CACHE_GID and set it in .firesim-lab.env."
  echo ""
fi
unset _conflicting_group

# ── Write .firesim-lab.env into the workspace ─────────────────────────────────
echo "$(_cyan "→ Writing settings to $ENV_FILE...")"

# Ensure the version pin is always defined before it is written (covers legacy
# workspaces loaded on a host with no installed manifest, which skip both the
# skew gate and the settings-prompt block above).
FIRESIM_LAB_VERSION="${FIRESIM_LAB_VERSION:-${INSTALLED_VERSION:-unknown}}"

cat > "$ENV_FILE" <<ENV
# ===========================================================================
# .firesim-lab.env — workspace settings for firesim-lab
# Workspace : $WORKSPACE_DIR
# Generated : $(date "+%Y-%m-%d %H:%M")
#
# This file is workspace-specific. Do not copy it between workspaces.
# Run 'firesim-lab --reconfigure' to update these settings.
# ===========================================================================

# ── Docker image and container ──────────────────────────────────────────────
# FIRESIM_LAB_VERSION pins this workspace to the firesim-lab version that
# created it.  The launcher refuses to start if the installed version differs
# (run 'firesim-lab --upgrade' to migrate).  Keeping it alongside the image
# also aids workspace migration between hosts.
FIRESIM_LAB_VERSION=${FIRESIM_LAB_VERSION}
FIRESIM_IMAGE=${FIRESIM_IMAGE}
CONTAINER_NAME=${CONTAINER_NAME}

# ── Workspace ───────────────────────────────────────────────────────────────
# Mounted as /target inside the container.
# All subdirectories (projects, build outputs) are persisted automatically.
HOST_WORKSPACE_DIR=${WORKSPACE_DIR}

# ── AWS configuration ───────────────────────────────────────────────────────
# Bind-mounted into the container as ~/.aws (HOME is fixed to /home/firesim-lab
# inside the container, so this path is the same for any host UID).  Anchored
# to the install dir so it never collides with the host's own ~/.aws and so
# the user does not need aws-cli installed on the host.
HOST_AWS_DIR=${HOST_AWS_DIR}

# ── SSH key directory ───────────────────────────────────────────────────────
# Bind-mounted into the container as ~/.ssh so SSH-aware tools (ssh, scp,
# git, rsync, ...) discover keys at the conventional location.  Anchored to
# the install dir so it never collides with the host's own ~/.ssh.
HOST_SSH_DIR=${HOST_SSH_DIR}

# ── Host user mapping ───────────────────────────────────────────────────────
HOST_UID=${HOST_UID}
HOST_GID=${HOST_GID}

# ── Cache group ──────────────────────────────────────────────────────────────
# GID of the firesim-lab-cache group baked into the container image.
# The entrypoint adds the host user to this group at container start so they
# can write to all pre-warmed cache directories (ivy2, coursier, sbt, ccache).
# Only change this if you rebuilt the image with a custom CACHE_GID build arg.
CACHE_GID=${CACHE_GID}

# ── Security ────────────────────────────────────────────────────────────────
ENABLE_CUSTOM_PLUGINS=${ENABLE_CUSTOM_PLUGINS}

# ── Performance tuning ──────────────────────────────────────────────────────
VERILATOR_THREADS=${VERILATOR_THREADS}
CONTAINER_MEMORY_LIMIT=${CONTAINER_MEMORY_LIMIT}
CONTAINER_MEMORY_RESERVE=${CONTAINER_MEMORY_RESERVE}

# ── Named volumes (user-specific, scoped to HOST_UID=${HOST_UID}) ────────────
# Each volume name embeds the host UID so that multiple users on the same
# Docker host have independent caches.  These names are baked into this env
# file and referenced directly by docker-compose — no variable arithmetic is
# performed at compose time, which avoids docker-compose substitution issues.
VOLUME_SBT_IVY=firesim-lab-sbt-ivy-${HOST_UID}
VOLUME_SBT_COURSIER=firesim-lab-sbt-coursier-${HOST_UID}
VOLUME_SBT_BOOT=firesim-lab-sbt-boot-${HOST_UID}
VOLUME_SBT_GLOBAL=firesim-lab-sbt-global-${HOST_UID}
VOLUME_CCACHE=firesim-lab-verilator-ccache-${HOST_UID}
ENV

echo "  $(_green "✓") Settings saved"
echo ""

# ── Summary ───────────────────────────────────────────────────────────────────
echo "  $(_bold "Configuration")"
echo "  ─────────────────────────────────────────────────────────"
echo "  Version        : $(_cyan "${FIRESIM_LAB_VERSION:-unknown}")"
echo "  Image          : $(_cyan "$FIRESIM_IMAGE")"
echo "  Container      : $CONTAINER_NAME"
echo "  Workspace      : $WORKSPACE_DIR  →  /target"
if [[ -n "$PROJECT_NAME" ]]; then
echo "  Project        : $PROJECT_NAME   →  /target/$PROJECT_NAME"
fi
echo "  AWS config     : $HOST_AWS_DIR  →  ~/.aws"
echo "  SSH keys       : $HOST_SSH_DIR  →  ~/.ssh"
echo "  Host UID:GID   : $HOST_UID:$HOST_GID"
echo "  Cache GID      : $CACHE_GID  (firesim-lab-cache, baked into image)"
echo "  Verilator jobs : $VERILATOR_THREADS"
echo "  Memory limit   : $CONTAINER_MEMORY_LIMIT (reserve: $CONTAINER_MEMORY_RESERVE)"
echo "  ─────────────────────────────────────────────────────────"
echo ""

# ── Image check / pull ────────────────────────────────────────────────────────
echo "$(_cyan "→ Checking Docker image: $FIRESIM_IMAGE...")"

_try_pull() {
  echo "  $(_cyan "→ Pulling $FIRESIM_IMAGE...")"
  if docker pull "$FIRESIM_IMAGE" 2>/dev/null || true; then
    if docker image inspect "$FIRESIM_IMAGE" &>/dev/null; then
      echo "  $(_green "✓") Image pulled successfully."
    else
      echo "  $(_red "✗  Pull failed — the image could not be retrieved.")"
      echo "     This compose file is pull-only (no local build).  Check the image"
      echo "     name/tag, your network, and 'docker login' if it is private."
    fi
  fi
}

if ! docker image inspect "$FIRESIM_IMAGE" &>/dev/null; then
  echo "  $(_yellow "⚠  Image not found locally.")"
  if [[ $DO_PULL -eq 1 ]]; then
    _try_pull
  else
    read -p "     Pull it now? [Y/n]: " yn
    yn="${yn:-Y}"
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      _try_pull
    else
      echo "  $(_yellow "⚠  Skipping pull — container start will fail if the image is absent.")"
    fi
  fi
else
  echo "  $(_green "✓") Image found locally: $FIRESIM_IMAGE"
  [[ $DO_PULL -eq 1 ]] && _try_pull
fi

echo ""

# ── Container lifecycle ───────────────────────────────────────────────────────
_container_running() {
  docker ps --filter "name=^/${CONTAINER_NAME}$" --filter "status=running" -q \
    | grep -q .
}

_container_exists() {
  docker ps -a --filter "name=^/${CONTAINER_NAME}$" -q \
    | grep -q .
}

_wait_for_container() {
  local max_wait=60
  local waited=0
  echo -n "  $(_cyan "→ Waiting for container to be ready")"
  while ! _container_running; do
    if [[ $waited -ge $max_wait ]]; then
      echo ""
      echo "  $(_red "✗ Container did not start within ${max_wait}s.")"
      echo "  Check logs: docker logs $CONTAINER_NAME"
      exit 1
    fi
    echo -n "."
    sleep 1
    (( waited++ ))
  done
  echo " $(_green "ready")"
}

_enter_shell() {
  echo "  $(_bold "$(_cyan "[ ENTERING CONTAINER SHELL — type 'exit' to return to host ]")")"
  echo ""
  local rc
  rc=$(mktemp "${TMPDIR:-/tmp}/firesim-lab-rc.XXXXXX")
  {
    echo 'source /etc/bash.bashrc 2>/dev/null'
    echo 'source ~/.bashrc 2>/dev/null'
    echo "PS1='(firesim-lab \[\033[36m\]\w\[\033[0m\]) $ '"
    echo "printf '%b\n' '\033[1m\033[36m'"
    echo "printf '%b\n' '  ███████╗██╗██████╗ ███████╗███████╗██╗███╗   ███╗      ██╗      █████╗ ██████╗'"
    echo "printf '%b\n' '  ██╔════╝██║██╔══██╗██╔════╝██╔════╝██║████╗ ████║      ██║     ██╔══██╗██╔══██╗'"
    echo "printf '%b\n' '  █████╗  ██║██████╔╝█████╗  ███████╗██║██╔████╔██║█████╗██║     ███████║██████╔╝'"
    echo "printf '%b\n' '  ██╔══╝  ██║██╔══██╗██╔══╝  ╚════██║██║██║╚██╔╝██║╚════╝██║     ██╔══██║██╔══██╗'"
    echo "printf '%b\n' '  ██║     ██║██║  ██║███████╗███████║██║██║ ╚═╝ ██║      ███████╗██║  ██║██████╔╝'"
    echo "printf '%b\n' '  ╚═╝     ╚═╝╚═╝  ╚═╝╚══════╝╚══════╝╚═╝╚═╝     ╚═╝      ╚══════╝╚═╝  ╚═╝╚═════╝'"
    echo "printf '%b\n' '\033[0m'"
    echo "printf '%b\n' '  \033[1mWorkspace\033[0m : /target  \033[2m(host: ${WORKSPACE_DIR})\033[0m'"
    echo "printf '%b\n' '  \033[1mProject\033[0m   : ${PROJECT_NAME:-(none detected)}'"
    echo "printf '%b\n' '  \033[1mImage\033[0m     : ${FIRESIM_IMAGE}'"
    echo "printf '%b\n' ''"
    echo "printf '%b\n' '  \033[1mQuick reference:\033[0m'"
    echo "printf '%b\n' '    fslab new <my-project>                           — Scaffold a new project'"
    echo "printf '%b\n' '    cd /target/<my-project>                          — Copy design sources   '"
    echo "printf '%b\n' '                                                       (.v, .sv) to user_rtl'"
    echo "printf '%b\n' '    fslab init -t <top module> -f <top module file>  — generate fslab.yaml'"
    echo "printf '%b\n' '                                                       then update fslab.yaml'"
    echo "printf '%b\n' '    fslab generate                                   — generate sim sources'"
    echo "printf '%b\n' '    fslab sim                                        — run simulation'"
    echo "printf '%b\n' '    fslab --help                                     — Show help'"
    echo "printf '%b\n' ''"
    echo "printf '%b\n' '  \033[1mAWS:\033[0m run \033[36maws configure sso --use-device-code\033[0m or \033[36maws sso login --use-device-code --profile <profile>\033[0m — credentials persist to ${HOST_AWS_DIR} on the host.'"
    echo "printf '%b\n' '  \033[1mSSH:\033[0m place private keys (e.g. .pem) under ${HOST_SSH_DIR} on the host (chmod 600) — they appear as \033[36m~/.ssh\033[0m in the container.'"
    echo "printf '%b\n' ''"
    echo "printf '%b\n' '  \033[2mType exit to return to host shell.\033[0m'"
    echo "printf '%b\n' ''"
  } > "$rc"
  docker cp "$rc" "$CONTAINER_NAME:/tmp/.firesim-lab-rc" > /dev/null 2>&1 && rm "$rc"
  docker exec -it "$CONTAINER_NAME" \
    firesim-lab-shell bash --rcfile /tmp/.firesim-lab-rc
}

if _container_running; then
  echo "  $(_green "✓") Container already running."
  echo ""
  _enter_shell
  exit 0
fi

if _container_exists; then
  echo "  $(_yellow "⚠  Container exists but is stopped — restarting...")"
  docker start "$CONTAINER_NAME"
else
  echo "$(_cyan "→ Starting container...")"
  _compose up -d
fi

_wait_for_container

echo ""
echo "  $(_green "✓  Container '$CONTAINER_NAME' is running.")"
echo ""

# ── Post-start instructions ───────────────────────────────────────────────────
# Use the detected/confirmed project name, or a placeholder for new workspaces.
_project="${PROJECT_NAME:-<my-project>}"

if [[ -z "$PROJECT_NAME" ]]; then
  # New workspace — no project scaffolded yet
  echo "  $(_yellow "ℹ  No firesim-lab project found in this workspace.")"
  echo "  $(_bold "Start a new project inside the container:")"
  echo ""
  echo "    $(_cyan "fslab new $_project")  "
  echo ""

elif [[ ! -f "$WORKSPACE_DIR/$PROJECT_NAME/fslab.yaml" ]]; then
  # Project directory exists (has build.sbt) but scaffold is incomplete
  echo "  $(_yellow "⚠  Project '$PROJECT_NAME' has not been fully initialized yet.")"
  echo "  $(_bold "Complete it inside the container:")"
  echo ""
  echo "    $(_bold "Copy your designs (.v, .sv) to $PROJECT_NAME/user_rtl first.")"
  echo ""
  echo "    $(_cyan "fslab init --top-module <top module name> \\")  "
  echo "    $(_cyan "           --top-module-file <top module file path \\")  "
  echo "    $(_cyan "           --platform <platform> \\")  "
  echo ""

else
  # Fully scaffolded project — show build commands
  echo "  $(_bold "Build and run your target:")"
  echo "    cd /target/$PROJECT_NAME"
  echo "    fslab sim"
fi

echo ""
echo "  $(_bold "Opening shell — 'exit' leaves the shell but keeps the container running.")"
echo "  $(_bold "To stop the container:") firesim-lab --down"
echo ""

_enter_shell
