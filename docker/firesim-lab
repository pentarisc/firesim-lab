_try_pull() {
  echo "  $(_cyan "вҶ’ Pulling $FIRESIM_IMAGE...")"
  if docker pull "$FIRESIM_IMAGE" 2>/dev/null || true; then
    if docker image inspect "$FIRESIM_IMAGE" &>/dev/null; then
      echo "  $(_green "вң“") Image pulled successfully."
    else
      echo "  $(_yellow "вҡ   Pull failed вҖ” docker-compose will attempt a local build.")"
    fi
  fi
}

