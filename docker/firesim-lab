  echo "  $(_yellow "вҡ   Image not found locally.")"
  if [[ $DO_PULL -eq 1 ]]; then
    _try_pull
  else
    read -p "     Pull it now? [Y/n]: " yn
    yn="${yn:-Y}"
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      _try_pull
    else
      echo "  $(_yellow "вҡ   Skipping pull вҖ” will attempt local build if needed.")"
