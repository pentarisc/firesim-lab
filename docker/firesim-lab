#!/usr/bin/env bash
# =============================================================================
#  firesim-lab вҖ” simulation environment launcher
#
#  Installed once to ~/.firesim-lab/docker/ and symlinked into your PATH by
#  install.sh.  Run from any workspace directory.
#
#  On first run in a new directory (no .firesim-lab.env):
#    Auto-detects any existing firesim-lab project in the workspace.
#    Prompts for image/thread settings, writes .firesim-lab.env, starts the
#    container, and drops you into a shell.
#
#  On subsequent runs (.firesim-lab.env already exists):
#    Reads saved settings silently, starts or enters the container.
#
#  Usage:
#    cd ~/my-workspace && firesim-lab                  # start / enter
#    cd ~/my-workspace && firesim-lab --down           # stop container
#    cd ~/my-workspace && firesim-lab --pull           # pull fresh image
#    cd ~/my-workspace && firesim-lab --reconfigure    # re-prompt settings
#    cd ~/my-workspace && firesim-lab --status         # show container info
#    cd ~/my-workspace && firesim-lab --clean-cache    # wipe SBT/ccache volumes
#
#  Non-interactive (CI / scripted):
#    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab
# =============================================================================

set -euo pipefail

# в”Җв”Җ Pipe-detection guard в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_first_arg="${1:-}"
_non_interactive_safe=0
case "$_first_arg" in
  -h|--help|--down|--pull|--clean-cache|--status) _non_interactive_safe=1 ;;
esac

if [[ ! -t 0 && $_non_interactive_safe -eq 0 ]]; then
  cat >&2 <<PIPE_ERR

  ERROR: firesim-lab cannot be piped directly.

  It uses interactive prompts and must be run from a local installation.
  The correct entry point is install.sh:

    curl -sSL https://raw.githubusercontent.com/pentarisc/firesim-lab/main/install.sh | bash

PIPE_ERR
  exit 1
fi

# в”Җв”Җ Locate installation directory в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Resolve symlinks so INSTALL_DIR always points to the real installation folder
# even when invoked through a PATH symlink.
_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" && pwd
}
INSTALL_DIR="$(_resolve_script_dir)"

# в”Җв”Җ Workspace is always the current working directory в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
WORKSPACE_DIR="$(pwd)"
WORKSPACE_BASENAME="$(basename "$WORKSPACE_DIR")"
ENV_FILE="$WORKSPACE_DIR/.firesim-lab.env"

# в”Җв”Җ Static configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
REPO_RAW="https://raw.githubusercontent.com/pentarisc/firesim-lab/main"
COMPOSE_URL="${REPO_RAW}/docker/docker-compose.yaml"
COMPOSE_FILE="$INSTALL_DIR/docker-compose.yaml"

DEFAULT_IMAGE="firesim-lab:latest"
DEFAULT_VERILATOR_THREADS=$(nproc 2>/dev/null || echo 4)
DEFAULT_MEMORY_LIMIT="16g"
DEFAULT_MEMORY_RESERVE="8g"

# Container name is workspace-scoped only вҖ” one container per workspace.
# Illegal docker name characters are replaced with '-'.
CONTAINER_NAME="firesim-lab-$(echo "$WORKSPACE_BASENAME" | tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/-*$//')"

# в”Җв”Җ Colour helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_bold()  { printf '\033[1m%s\033[0m' "$*"; }
_green() { printf '\033[32m%s\033[0m' "$*"; }
_cyan()  { printf '\033[36m%s\033[0m' "$*"; }
_yellow(){ printf '\033[33m%s\033[0m' "$*"; }
_red()   { printf '\033[31m%s\033[0m' "$*"; }

# в”Җв”Җ Help в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
usage() {
  cat <<USAGE

  $(_bold "firesim-lab") вҖ” FireSim standalone simulation environment

  Run from any workspace directory. Settings are saved per-workspace in
  .firesim-lab.env so you never have to re-enter them.

  $(_bold "Usage:")
    $(_cyan "cd ~/my-workspace")
    $(_cyan "firesim-lab")                  # start container (or enter if running)
    $(_cyan "firesim-lab --down")           # stop the container
    $(_cyan "firesim-lab --pull")           # pull latest image and restart
    $(_cyan "firesim-lab --reconfigure")    # re-prompt all settings
    $(_cyan "firesim-lab --status")         # show container status
    $(_cyan "firesim-lab --clean-cache")    # remove SBT/ccache volumes
    $(_cyan "firesim-lab --help")           # show this message

  $(_bold "Non-interactive (env vars override prompts):")
    FIRESIM_IMAGE=firesim-lab:v2 firesim-lab

  $(_bold "Workspace layout:")
    <workspace>/                    вҶ’ mounted as /target inside the container
    в””в”Җв”Җ <project>/                  вҶ’ auto-detected firesim-lab project
        в”ңв”Җв”Җ build.sbt
        в”ңв”Җв”Җ env.sh
        в””в”Җв”Җ ...

  $(_bold "Settings file:") .firesim-lab.env  (written to each workspace directory)

USAGE
}

# в”Җв”Җ Parse arguments в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
DO_DOWN=0
DO_PULL=0
DO_CLEAN_CACHE=0
DO_RECONFIGURE=0
DO_STATUS=0

for arg in "$@"; do
  case "$arg" in
    -h|--help)      usage; exit 0 ;;
    --down)         DO_DOWN=1 ;;
    --pull)         DO_PULL=1 ;;
    --clean-cache)  DO_CLEAN_CACHE=1 ;;
    --reconfigure)  DO_RECONFIGURE=1 ;;
    --status)       DO_STATUS=1 ;;
    *)
      echo "$(_red "Unknown option:") $arg"
      usage
      exit 1
      ;;
  esac
done

# в”Җв”Җ Detect docker compose command в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if docker compose version &>/dev/null 2>&1; then
  COMPOSE="docker compose"
elif command -v docker-compose &>/dev/null; then
  COMPOSE="docker-compose"
else
  echo "$(_red "Error:") Neither 'docker compose' nor 'docker-compose' found."
  echo "Install Docker Desktop (macOS/Windows) or docker-compose-plugin (Linux)."
  exit 1
fi

# в”Җв”Җ Ensure docker-compose.yaml is present in install dir в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ ! -f "$COMPOSE_FILE" ]]; then
  echo "$(_cyan "вҶ’ Downloading docker-compose.yaml...")"
  if command -v curl &>/dev/null; then
    curl -fsSL "$COMPOSE_URL" -o "$COMPOSE_FILE"
  elif command -v wget &>/dev/null; then
    wget -qO "$COMPOSE_FILE" "$COMPOSE_URL"
  else
    echo "$(_red "Error:") curl or wget required to download docker-compose.yaml"
    exit 1
  fi
  echo "$(_green "вң“") docker-compose.yaml downloaded to $INSTALL_DIR"
fi

# в”Җв”Җ Shared compose invocation (always uses workspace .env) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_compose() {
  $COMPOSE --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

# в”Җв”Җ Handle --clean-cache в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ $DO_CLEAN_CACHE -eq 1 ]]; then
  echo "$(_yellow "вҡ   Removing all named SBT and ccache volumes...")"
  docker volume rm \
    firesim-lab-sbt-ivy \
    firesim-lab-sbt-coursier \
    firesim-lab-sbt-boot \
    firesim-lab-sbt-global \
    firesim-lab-verilator-ccache \
    2>/dev/null || true
  echo "$(_green "вң“") Cache volumes removed. They will be re-seeded on next start."
  exit 0
fi

# в”Җв”Җ Handle --status в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ $DO_STATUS -eq 1 ]]; then
  echo ""
  echo "  $(_bold "Workspace") : $WORKSPACE_DIR"
  echo "  $(_bold "Container") : $CONTAINER_NAME"
  echo ""
  docker ps -a --filter "name=^/${CONTAINER_NAME}$" \
    --format "  Status    : {{.Status}}\n  Image     : {{.Image}}\n  Created   : {{.RunningFor}}" \
    || echo "  $(_yellow "(no container found)")"
  echo ""
  exit 0
fi

# в”Җв”Җ Handle --down в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ $DO_DOWN -eq 1 ]]; then
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$(_red "Error:") No .firesim-lab.env found in $WORKSPACE_DIR"
    echo "Nothing to stop."
    exit 1
  fi
  echo "$(_cyan "вҶ’ Stopping container:") $CONTAINER_NAME"
  _compose down
  echo "$(_green "вң“") Container stopped."
  exit 0
fi

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo ""
echo "  $(_bold "firesim-lab") вҖ” workspace: $(_cyan "$WORKSPACE_DIR")"
echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
echo ""

# в”Җв”Җ Auto-detect firesim-lab project(s) in workspace в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# A firesim-lab project is identified by a build.sbt in a first-level
# subdirectory that contains "FIRESIM_LAB_ROOT" вҖ” a string unique to projects
# generated by init-target and not expected in unrelated SBT projects.
_detect_projects() {
  local dir sbt
  for dir in "$WORKSPACE_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    sbt="${dir}build.sbt"
    if [[ -f "$sbt" ]] && grep -q "FIRESIM_LAB_ROOT" "$sbt"; then
      basename "$dir"
    fi
  done
}

echo "$(_cyan "вҶ’ Scanning workspace for firesim-lab projects...")"

mapfile -t DETECTED < <(_detect_projects)

PROJECT_NAME=""   # empty = new workspace / no project selected

if [[ ${#DETECTED[@]} -eq 0 ]]; then
  # в”Җв”Җ No project found в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  echo "  $(_yellow "в„№  No firesim-lab project detected.")"
  echo "     Scaffold one with init-target once the container is running."

elif [[ ${#DETECTED[@]} -eq 1 ]]; then
  # в”Җв”Җ Exactly one project вҖ” confirm with user в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  echo "  $(_green "вң“") Detected project: $(_bold "${DETECTED[0]}")"
  read -p "     Use this project? [Y/n]: " yn
  yn="${yn:-Y}"
  if [[ "$yn" =~ ^[Yy]$ ]]; then
    PROJECT_NAME="${DETECTED[0]}"
  else
    echo "  $(_yellow "в„№  Skipping detected project вҖ” no project will be active.")"
  fi

else
  # в”Җв”Җ Multiple projects вҖ” warn and ask user to pick в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  echo "  $(_yellow "вҡ   Multiple firesim-lab projects detected.")"
  echo "     Only one project per workspace is supported."
  echo ""
  local i=1
  for name in "${DETECTED[@]}"; do
    echo "     $i) $name"
    (( i++ ))
  done
  echo ""
  while true; do
    read -p "     Enter the project name to use: " PROJECT_NAME
    local valid=0
    for name in "${DETECTED[@]}"; do
      [[ "$name" == "$PROJECT_NAME" ]] && valid=1 && break
    done
    if [[ $valid -eq 1 ]]; then
      echo "  $(_green "вң“") Using project: $PROJECT_NAME"
      break
    else
      echo "  $(_red "вң—") '$PROJECT_NAME' is not one of the detected projects. Try again."
    fi
  done
fi

echo ""

# в”Җв”Җ Load existing .env or collect settings в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_env_loaded=0
if [[ -f "$ENV_FILE" && $DO_RECONFIGURE -eq 0 ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  _env_loaded=1
  echo "  $(_green "вң“") Loaded settings from .firesim-lab.env"
  echo "      Image : $FIRESIM_IMAGE   Threads : $VERILATOR_THREADS"
  echo ""
fi

if [[ $_env_loaded -eq 0 || $DO_RECONFIGURE -eq 1 ]]; then
  # в”Җв”Җ Docker image в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if [[ -z "${FIRESIM_IMAGE:-}" ]]; then
    read -e -p "  $(_bold "Docker image name:tag") [$DEFAULT_IMAGE]: " FIRESIM_IMAGE
  fi
  FIRESIM_IMAGE="${FIRESIM_IMAGE:-$DEFAULT_IMAGE}"

  # в”Җв”Җ Verilator threads в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if [[ -z "${VERILATOR_THREADS:-}" ]]; then
    read -e -p "  $(_bold "Verilator parallel jobs") [$DEFAULT_VERILATOR_THREADS]: " VERILATOR_THREADS
  fi
  VERILATOR_THREADS="${VERILATOR_THREADS:-$DEFAULT_VERILATOR_THREADS}"

