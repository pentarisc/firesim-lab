#!/bin/bash
# =============================================================================
#  firesim-lab-shell — privilege-dropping shell entry point
#
#  Installed in the image at /usr/local/bin/firesim-lab-shell.
#  Intended to be called via `docker exec` so that interactive shells entered
#  after container start run as the host user rather than root.
#
#  Why this exists instead of `docker exec -u HOST_UID`:
#    `docker exec -u` calls setuid()/setgid() but does NOT call initgroups().
#    This means supplementary groups (in particular firesim-lab-cache, which
#    grants write access to the pre-warmed cache directories) are absent from
#    the shell.  gosu always calls initgroups(), so the full group membership
#    established by entrypoint.sh is correctly inherited.
#
#  HOST_UID is detected from the ownership of /target (the workspace bind
#  mount) rather than from an environment variable.  This matches the approach
#  used by entrypoint.sh and requires no environment variable plumbing.
#
#  Usage (called by the firesim-lab run script):
#    docker exec -it <container> firesim-lab-shell <command> [args...]
# =============================================================================
set -euo pipefail

HOST_UID=$(stat -c '%u' /target)

# See entrypoint.sh for the full rationale: a root-owned /target can mean
# either a rootless-userns-mapped runtime (expected, correct — /proc/self/
# uid_map shows a non-identity mapping) or a genuinely root-owned workspace
# under a rootful runtime (a real misconfiguration).
if [[ "${HOST_UID}" -eq 0 ]]; then
    if [[ "$(awk 'NR==1{print $2; exit}' /proc/self/uid_map 2>/dev/null)" != "0" ]]; then
        echo "[firesim-lab-shell] Rootless container runtime detected; running as the mapped user." >&2
    else
        echo "[firesim-lab-shell] WARNING: /target is owned by root; running as root." >&2
    fi
    exec "$@"
fi

if [[ $# -eq 0 ]]; then
    echo "[firesim-lab-shell] ERROR: No command specified." >&2
    echo "[firesim-lab-shell] Usage: firesim-lab-shell <command> [args...]" >&2
    exit 1
fi

exec gosu "${HOST_UID}" "$@"
