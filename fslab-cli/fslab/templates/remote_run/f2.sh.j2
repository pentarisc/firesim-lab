{#-
  remote_run/f2.sh.j2 — AWS F2 detached-run wrapper script
  ========================================================

  Rendered just-in-time by `fslab sim fpga --detach` into
  `<project_root>/run/fpga/staging/remote_run_f2.sh` and uploaded fresh
  to the remote slot dir on every invocation. NOT rendered by
  `fslab generate` — the wrapper is purely orchestrator-internal and
  re-rendered per run so per-run params can be baked into env vars
  rather than into the script body.

  Lifecycle once launched (in `nohup` background):

    1. Write the *remote stamp* (containing $RUN_ID + metadata) so
       `fslab monitor run` can SSH in and verify the running run's
       identity before tailing logs.
    2. Verify payload hashes against $SLOT_DIR/SHA256SUMS when gated
       in (VERIFY_HASH != NO and HAS_SHA256SUMS == 1). Runs BEFORE
       the FPGA is touched so a manifest mismatch never costs a
       bitstream load. A failure here lands in result.yaml as
       failure.stage=hash_verify.
    3. `sudo fpga-clear-local-image -S $SLOT -A`   (idempotent reset)
       then busy-wait until `fpga-describe-local-image` reports
       `cleared` — the management commands return as soon as the
       request is queued, and the FPGA stays in (3) busy until the
       operation actually completes.
    4. `sudo fpga-load-local-image -S $SLOT -I $AGFI -A`, then busy-
       wait for `loaded`. Uses the EC2 instance profile attached to
       the run host — see run-pipeline-handoff D4 for the minimal IAM
       policy (DescribeFpgaImages + AssociateFpgaImage).
    5. Exec the driver under `sudo bash -lc "..."`. AWS F2 requires
       root for FPGA BAR access / AFI introspection (without it the
       driver fails with "Unable to get AFI information from slot ...
       Are you running as root?"). `bash -lc` is a login shell so
       /etc/profile.d/aws-fpga.sh and similar are sourced inside the
       elevated session. Passwordless sudo for the configured
       `ssh_user` is a firesim-lab requirement.
    6. Always (success or failure): write `result.yaml` with status,
       exit_code, and `failure.stage` if applicable. The EXIT trap
       guarantees the file is written even on `set -e` aborts mid-stage.
    7. Teardown: `sudo fpga-clear-local-image -S $SLOT -A` (best effort).

  Driver completion = wrapper completion. Unlike the F2 build side,
  there is no post-wrapper polling phase — the driver's exit code is
  terminal (per D9 in the run-pipeline handoff).

  Input contract
  --------------
  Per-run env vars set by the local `fslab sim fpga --detach`:

    RUN_ID             opaque run identifier (matches local stamp)
    AGFI               agfi-... to load onto the FPGA slot
    SLOT_DIR           absolute remote slot dir (driver + .fslab/ live here)
    STAMP_PATH         remote stamp file (for monitor run_id verification)
    LOG_PATH           wrapper's combined stdout/stderr capture path
                       (the `driver.log` artifact monitor pulls back)
    RESULT_PATH        result.yaml destination

    DRIVER_BASENAME    name of the driver binary in $SLOT_DIR
    MAX_CYCLES         optional integer; empty/0 ⇒ no +max-cycles flag
    EXTRA_FLAGS        space-separated verbatim extra driver flags (or empty)

    VERIFY_HASH        YES | NO | IF_PRESENT — sha256 verification policy.
                       The wrapper only acts when this is not "NO".
    HAS_SHA256SUMS     "1" if the launcher uploaded SHA256SUMS into
                       $SLOT_DIR, empty otherwise. Lets the wrapper skip
                       the verify step without poking the filesystem.

  Project-static config rendered by Jinja2 below:

    PLATFORM           "f2"
    PROJECT_NAME       project.name
    SLOT               FPGA slot id (currently always 0)
-#}
#!/usr/bin/env bash
# Generated by `fslab sim fpga --detach` from templates/remote_run/f2.sh.j2.
# Re-rendered on every detached run — local edits will be overwritten.

# -e is essential: without it, a failed `fpga-load-local-image` (or any
# stage before the driver) silently falls through to the next command
# and the driver runs against an FPGA that was never programmed —
# masking the real cause behind a generic driver failure in result.yaml.
set -euo pipefail

# ---------------------------------------------------------------------------
# Per-run inputs (set by `fslab sim fpga --detach` when invoking this script).
# `:?` produces a clear error if a required var is missing.
# ---------------------------------------------------------------------------
: "${RUN_ID:?RUN_ID env var is required}"
: "${AGFI:?AGFI env var is required}"
: "${SLOT_DIR:?SLOT_DIR env var is required}"
: "${STAMP_PATH:?STAMP_PATH env var is required}"
: "${LOG_PATH:?LOG_PATH env var is required}"
: "${RESULT_PATH:?RESULT_PATH env var is required}"
: "${DRIVER_BASENAME:?DRIVER_BASENAME env var is required}"
MAX_CYCLES="${MAX_CYCLES:-}"
EXTRA_FLAGS="${EXTRA_FLAGS:-}"
# Payload-axis env vars are optional. Defaults preserve the pre-payload
# behaviour: NO verification, no manifest present.
VERIFY_HASH="${VERIFY_HASH:-NO}"
HAS_SHA256SUMS="${HAS_SHA256SUMS:-}"

# ---------------------------------------------------------------------------
# Project-static config (rendered by Jinja2).
# ---------------------------------------------------------------------------
PLATFORM="{{ platform_id }}"
PROJECT_NAME="{{ project_name }}"
SLOT="{{ fpga_slot }}"

# AGFI clear and load typically complete in well under a minute on a
# warm F2 host, but a cold spot warm-up plus an unlucky queue can stretch
# them. 1 hour is the ceiling — beyond that we'd rather surface a timeout
# than busy-wait forever (FireSim's loops have no timeout at all).
FPGA_STATE_TIMEOUT_S=3600

# ---------------------------------------------------------------------------
# 1. Write the remote stamp first — monitor uses its `run_id` to verify
#    that the wrapper actually started and that the remote/local stamps
#    are talking about the same run.
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$STAMP_PATH")"
cat > "$STAMP_PATH" <<EOF
run_id: $RUN_ID
started_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
hostname: $(hostname)
project_name: $PROJECT_NAME
platform: $PLATFORM
agfi: $AGFI
EOF

# ---------------------------------------------------------------------------
# EXIT trap composes result.yaml. CURRENT_STAGE is set immediately before
# each stage so the trap captures the right `failure.stage` on abort.
# ---------------------------------------------------------------------------
CURRENT_STAGE="init"
FAILURE_MESSAGE=""

write_result() {
  # Capture $? immediately — any other command would clobber it.
  local rc=$?
  local status="failed"
  [[ $rc -eq 0 ]] && status="succeeded"
  mkdir -p "$(dirname "$RESULT_PATH")"
  cat > "$RESULT_PATH" <<EOF
run_id: $RUN_ID
status: $status
exit_code: $rc
started_at: $(grep '^started_at:' "$STAMP_PATH" 2>/dev/null | awk '{print $2}')
finished_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
artifact_source:
  type: aws_afi
  agfi: $AGFI
artifacts:
  driver_log: $LOG_PATH
failure:
  stage: $CURRENT_STAGE
  message: $FAILURE_MESSAGE
EOF
  # Teardown — best effort; never aborts the trap. Idempotent.
  sudo fpga-clear-local-image -S "$SLOT" -A 2>/dev/null || true
}
trap write_result EXIT

# ---------------------------------------------------------------------------
# Wait until the FPGA slot reports the requested state ("cleared" or
# "loaded"). The clear/load mgmt commands return as soon as the request
# is queued; without this gate, the next command races the FPGA and
# fails with `Error: (3) busy`. The inner pipeline is gated by `if`,
# so `pipefail` and `set -e` don't trip on transient `grep` misses.
# ---------------------------------------------------------------------------
wait_for_fpga_state() {
  local want="$1"
  local timeout="${2:-$FPGA_STATE_TIMEOUT_S}"
  local deadline=$(( $(date +%s) + timeout ))
  echo "[fslab] Waiting for FPGA slot $SLOT to report '$want' (timeout ${timeout}s)"
  while (( $(date +%s) < deadline )); do
    if sudo fpga-describe-local-image -S "$SLOT" -R -H 2>/dev/null \
         | grep -q "$want"; then
      return 0
    fi
    sleep 1
  done
  FAILURE_MESSAGE="FPGA slot $SLOT did not reach state '$want' within ${timeout}s"
  echo "[fslab] $FAILURE_MESSAGE" >&2
  return 1
}

# ---------------------------------------------------------------------------
# 2. Payload hash verification (gated). Runs before any FPGA mgmt command
#    so a corrupt payload never costs a bitstream load. Failure here is
#    captured by the EXIT trap as failure.stage=hash_verify.
#
#    `sha256sum -c` runs from $SLOT_DIR because the manifest references
#    payloads by basename and the launcher uploaded them next to
#    SHA256SUMS in that dir.
# ---------------------------------------------------------------------------
CURRENT_STAGE=hash_verify
if [[ "$VERIFY_HASH" != "NO" && "$HAS_SHA256SUMS" == "1" ]]; then
  echo "[fslab] Verifying payload hashes via sha256sum -c"
  ( cd "$SLOT_DIR" && sha256sum -c SHA256SUMS )
else
  echo "[fslab] Skipping payload hash verification (VERIFY_HASH=$VERIFY_HASH, HAS_SHA256SUMS=${HAS_SHA256SUMS:-<empty>})"
fi

# ---------------------------------------------------------------------------
# 3. Clear + program AGFI. Failures here surface in result.yaml as
#    failure.stage = agfi_load.
# ---------------------------------------------------------------------------
CURRENT_STAGE=agfi_load
sudo fpga-clear-local-image -S "$SLOT" -A
wait_for_fpga_state "cleared"
sudo fpga-load-local-image -S "$SLOT" -I "$AGFI" -A
wait_for_fpga_state "loaded"

# ---------------------------------------------------------------------------
# 4. Run the driver. stdout+stderr already redirected to $LOG_PATH by the
#    nohup launch wrapper; this section's output is appended.
#
#    Driver runs under `sudo bash -lc` — F2 requires root for FPGA BAR
#    access, and a login shell brings /etc/profile.d/aws-fpga.sh into the
#    elevated session. Passwordless sudo for the configured ssh_user is
#    a firesim-lab requirement (documented in aws-setup-run.md).
# ---------------------------------------------------------------------------
CURRENT_STAGE=driver
cd "$SLOT_DIR"

# Compose the driver argv. MAX_CYCLES and EXTRA_FLAGS are optional.
DRIVER_ARGV=("./$DRIVER_BASENAME")
if [[ -n "$MAX_CYCLES" && "$MAX_CYCLES" != "0" ]]; then
  DRIVER_ARGV+=("+max-cycles=$MAX_CYCLES")
fi
if [[ -n "$EXTRA_FLAGS" ]]; then
  # Word-split EXTRA_FLAGS deliberately — the local CLI joins extra
  # driver flags with spaces and we want each token as a separate argv.
  # shellcheck disable=SC2206
  EXTRA_ARR=($EXTRA_FLAGS)
  DRIVER_ARGV+=("${EXTRA_ARR[@]}")
fi

# Quote each argv element for the `bash -lc` command string. `printf %q`
# emits a shell-safe form so embedded spaces / quotes don't tear argv
# boundaries inside the elevated login shell.
DRIVER_CMD=$(printf '%q ' "${DRIVER_ARGV[@]}")
echo "+ sudo bash -lc \"$DRIVER_CMD\""
sudo bash -lc "$DRIVER_CMD"

CURRENT_STAGE=done
