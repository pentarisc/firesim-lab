{#-
  remote_build/f2.sh.j2 — AWS F2 background-build wrapper script
  ==============================================================

  Rendered by `fslab generate` (via _render_templates in build.py) into
  `<project_root>/scripts/remote_build_f2.sh` — lives outside `build/`
  so it survives `fslab clean` and is checked-in alongside the project's
  other source artifacts. `fslab build fpga` uploads it fresh to the
  remote on every invocation and launches it in the background on the
  build host.

  Lifecycle once launched:

    1. Write the *remote stamp* (containing $BUILD_ID and metadata) so
       `fslab monitor build` can SSH in and verify the running build's
       identity before tailing logs.
    2. Ensure the S3 bucket exists (head-bucket probe; create on 404).
       Done up-front so a misconfigured bucket fails fast — before
       spending 30+ minutes on the Vivado build.
    3. Run build-bitstream.sh.
    4. On success: upload the DCP tar to S3 (instance-profile auth — no
       SSO from the workload's perspective).
    5. Submit `create-fpga-image` and capture AFI/AGFI ids.
    6. Always (success or failure): write `result.yaml` with status,
       exit_code, captured ids, and the stage at which a failure (if
       any) occurred. The EXIT trap guarantees the file is written even
       on `set -e` aborts mid-stage.

  AFI build itself runs in AWS-managed infrastructure after this script
  exits — local `fslab monitor build` polls `describe-fpga-images` via
  `BitBuilder.check_post_wrapper_status` to surface AFI state.

  Input contract
  --------------
  This script is invoked with the following env vars set by the local
  `fslab build` CLI at launch time. Per-build values change every run;
  BuildConfig-derived paths change when host/platform config changes
  (they live outside `fslab generate`'s context, so we receive them at
  invocation rather than bake them in).

    Per-build:
      BUILD_ID            opaque build identifier (matches local stamp)
      S3_KEY              target S3 key for the DCP tar under $S3_BUCKET
      AFI_NAME            name to register the AFI under (typically the
                          project name + build_id suffix; CLI composes)
      AFI_DESCRIPTION     human-readable description for the AFI

    BuildConfig-derived (set at invocation, not by `fslab generate`):
      CL_DIR              remote cl_<quintuplet> directory
      REMOTE_BUILD_SCRIPT absolute path to build-bitstream.sh on remote
      LOG_PATH            wrapper's combined stdout/stderr log path
      RESULT_PATH         result.yaml destination
      STAMP_PATH          remote stamp file (for monitor build_id check)

  Project-static config (fpga_frequency, build_strategy, s3 settings,
  region, dcp_glob) is rendered in by Jinja2 below. Re-render with
  `fslab generate` when those fields change in fslab.yaml.

  Error handling
  --------------
  `set -euo pipefail` aborts on the first non-zero command. CURRENT_STAGE
  is updated immediately before each stage's command so the EXIT trap
  writes the correct `failure.stage` in result.yaml. `pipefail` ensures
  failures inside pipelines (e.g. `aws ... | jq ...`) propagate.
-#}
#!/usr/bin/env bash
# Generated by fslab `generate` from templates/remote_build/f2.sh.j2.
# Do not edit manually — regenerate via `fslab generate`.

set -euo pipefail

# ---------------------------------------------------------------------------
# Build-time inputs (set by `fslab build` when invoking this script).
# `:?` produces a clear error if any required var is missing.
# ---------------------------------------------------------------------------
: "${BUILD_ID:?BUILD_ID env var is required}"
: "${S3_KEY:?S3_KEY env var is required}"
: "${AFI_NAME:?AFI_NAME env var is required}"
: "${CL_DIR:?CL_DIR env var is required}"
: "${REMOTE_BUILD_SCRIPT:?REMOTE_BUILD_SCRIPT env var is required}"
: "${LOG_PATH:?LOG_PATH env var is required}"
: "${RESULT_PATH:?RESULT_PATH env var is required}"
: "${STAMP_PATH:?STAMP_PATH env var is required}"
AFI_DESCRIPTION="${AFI_DESCRIPTION:-fslab F2 build ${BUILD_ID}}"

# ---------------------------------------------------------------------------
# Project-static config (rendered by `fslab generate`).
# ---------------------------------------------------------------------------
PROJECT_NAME="{{ project_name }}"
QUINTUPLET="{{ quintuplet }}"
DCP_GLOB="{{ dcp_glob }}"
FPGA_FREQUENCY="{{ fpga_frequency }}"
BUILD_STRATEGY="{{ build_strategy }}"
S3_BUCKET_BASE="{{ s3_bucket_base }}"
APPEND_USERID_REGION={{ "true" if append_userid_region else "false" }}
REGION="{{ aws_region }}"

# ---------------------------------------------------------------------------
# Resolve the effective S3 bucket. Mirrors AwsAfiPublisher's logic so the
# bucket name is consistent whether the upload happens locally (legacy
# synchronous path) or here on the remote.
# ---------------------------------------------------------------------------
if [[ "$APPEND_USERID_REGION" == "true" ]]; then
  USERID=$(aws sts get-caller-identity --query Account --output text)
  S3_BUCKET="${S3_BUCKET_BASE}-${USERID}-${REGION}"
else
  S3_BUCKET="$S3_BUCKET_BASE"
fi

# ---------------------------------------------------------------------------
# 1. Write the remote stamp first — monitor uses its `build_id` to verify
#    that the wrapper actually started and that the remote/local stamps
#    are talking about the same build.
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$STAMP_PATH")"
cat > "$STAMP_PATH" <<EOF
build_id: $BUILD_ID
started_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
hostname: $(hostname)
project_name: $PROJECT_NAME
platform: f2
EOF

# ---------------------------------------------------------------------------
# State the EXIT trap reads to compose result.yaml. Each stage sets
# CURRENT_STAGE *before* running its command so the trap captures the
# correct `failure.stage` when `set -e` aborts.
# ---------------------------------------------------------------------------
CURRENT_STAGE="init"
UPLOADED_BUCKET=""
UPLOADED_KEY=""
AFI_ID=""
AGFI_ID=""
FAILURE_MESSAGE=""

write_result() {
  # Capture $? immediately — any other command would clobber it.
  local rc=$?
  local status="failed"
  [[ $rc -eq 0 ]] && status="succeeded"
  mkdir -p "$(dirname "$RESULT_PATH")"
  cat > "$RESULT_PATH" <<EOF
build_id: $BUILD_ID
status: $status
exit_code: $rc
finished_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
artifacts:
  dcp_s3_bucket: $UPLOADED_BUCKET
  dcp_s3_key: $UPLOADED_KEY
  afi: $AFI_ID
  agfi: $AGFI_ID
failure:
  stage: $CURRENT_STAGE
  message: $FAILURE_MESSAGE
EOF
}
trap write_result EXIT

# ---------------------------------------------------------------------------
# 2. Ensure the S3 bucket exists. Mirrors `aws_fpga.ensure_bucket()` so the
#    remote wrapper is self-healing on a fresh AWS account / region: a 404
#    on head-bucket means we own the namespace and just haven't created
#    the bucket yet. Other failures (403 = someone else owns the global
#    namespace, or auth errors) are surfaced unchanged.
#
#    Done before the Vivado build so a misconfigured bucket fails in
#    seconds rather than after a 30+ minute build.
#
#    `aws s3api create-bucket` rejects --create-bucket-configuration in
#    us-east-1; every other region requires it.
# ---------------------------------------------------------------------------
CURRENT_STAGE=s3_ensure_bucket
HEAD_ERR=$(mktemp)
if aws s3api head-bucket --bucket "$S3_BUCKET" --region "$REGION" 2>"$HEAD_ERR"; then
  echo "S3 bucket s3://$S3_BUCKET already exists."
else
  if grep -qE '404|Not Found|NoSuchBucket' "$HEAD_ERR"; then
    echo "S3 bucket s3://$S3_BUCKET not found; creating in region $REGION."
    if [[ "$REGION" == "us-east-1" ]]; then
      aws s3api create-bucket --bucket "$S3_BUCKET" --region "$REGION"
    else
      aws s3api create-bucket --bucket "$S3_BUCKET" --region "$REGION" \
        --create-bucket-configuration "LocationConstraint=$REGION"
    fi
    echo "Created S3 bucket s3://$S3_BUCKET."
  else
    FAILURE_MESSAGE="head-bucket for s3://$S3_BUCKET failed in an unexpected way; see log."
    echo "head-bucket failed for s3://$S3_BUCKET — output:" >&2
    cat "$HEAD_ERR" >&2
    rm -f "$HEAD_ERR"
    exit 3
  fi
fi
rm -f "$HEAD_ERR"

# ---------------------------------------------------------------------------
# Give the boot-time data-volume filesystem grow a moment to settle before the
# build consumes the volume. When fslab.yaml sets `data_volume_gb`, cloud-init
# UserData (injected at launch) grows the data filesystem to fill the enlarged
# EBS block device; the resize is sub-second, but this fixed short wait removes
# any race between SSH-readiness and the grow completing. No-op when the volume
# was not resized.
# ---------------------------------------------------------------------------
sleep 2

# ---------------------------------------------------------------------------
# 3. Build (delegates to the platform's build-bitstream.sh, same as the
#    legacy synchronous flow).
# ---------------------------------------------------------------------------
CURRENT_STAGE=build
bash "$REMOTE_BUILD_SCRIPT" \
    --cl_dir "$CL_DIR" \
    --frequency "$FPGA_FREQUENCY" \
    --strategy "$BUILD_STRATEGY"

# ---------------------------------------------------------------------------
# 4. Locate the DCP tar produced by the build.
# ---------------------------------------------------------------------------
CURRENT_STAGE=locate_dcp
shopt -s nullglob
DCP_CANDIDATES=( $CL_DIR/$DCP_GLOB )
{% raw %}
if (( ${#DCP_CANDIDATES[@]} == 0 )); then
{% endraw %}
  FAILURE_MESSAGE="DCP tar not found at \$CL_DIR/\$DCP_GLOB ($CL_DIR/$DCP_GLOB)"
  exit 2
fi
DCP_TAR="${DCP_CANDIDATES[0]}"

# ---------------------------------------------------------------------------
# 5. S3 upload. Authenticated via the EC2 instance profile attached at
#    launch — no SSO, no expiring tokens from the workload's perspective.
#    This is the failure mode the redesign is built around.
# ---------------------------------------------------------------------------
CURRENT_STAGE=s3_upload
aws s3 cp "$DCP_TAR" "s3://$S3_BUCKET/$S3_KEY"
UPLOADED_BUCKET="$S3_BUCKET"
UPLOADED_KEY="$S3_KEY"

# ---------------------------------------------------------------------------
# 6. Submit create-fpga-image. The actual AFI build runs in AWS-managed
#    infra after this script exits; local monitor polls
#    `describe-fpga-images` to surface progress.
# ---------------------------------------------------------------------------
CURRENT_STAGE=create_fpga_image
RESP=$(aws ec2 create-fpga-image \
    --input-storage-location "Bucket=$S3_BUCKET,Key=$S3_KEY" \
    --logs-storage-location "Bucket=$S3_BUCKET,Key=logs/" \
    --name "$AFI_NAME" \
    --description "$AFI_DESCRIPTION")
AFI_ID=$(echo "$RESP" | jq -r .FpgaImageId)
AGFI_ID=$(echo "$RESP" | jq -r .FpgaImageGlobalId)

CURRENT_STAGE=done
