    val {{ instance.name }}_nastiKey = NastiParameters(dataBits = {{ instance.params.data_bits.value }},
                                   addrBits = {{ instance.params.addr_bits.value }},
                                   idBits = {{ instance.params.id_bits.value }})
    
    val {{ instance.name }}_nasti    = Wire(new NastiIO({{ instance.name }}_nastiKey))

    val MEM_BASE = BigInt("{{ instance.params.mem_base.value }}", 16)
    val MEM_SIZE = BigInt("{{ instance.params.mem_size.value }}", 16)

    val masterParams = AXI4MasterPortParameters(
      masters = Seq(AXI4MasterParameters(
        name = "main_mem_master",
        id   = IdRange(0, 1 << {{ instance.params.id_bits.value }}),
