        regionType = RegionType.UNCACHED,
        supportsRead  = TransferSizes(1, 64),
        supportsWrite = TransferSizes(1, 64),
        interleavedId = Some(0))),
      beatBytes = {{ instance.params.data_bits.value }} / 8)

    val edge = AXI4EdgeParameters(masterParams, slaveParams,
      params = Parameters.empty, sourceInfo = chisel3.experimental.SourceInfo.materialize)
    
    // ── AXI4 write address ────────────────────────────────────────────────────
    {{ instance.name }}_nasti.aw.valid       := dut.io.{{ instance.port_map.m_aw_valid }}
    {{ instance.name }}_nasti.aw.bits.id     := dut.io.{{ instance.port_map.m_aw_id }}
    {{ instance.name }}_nasti.aw.bits.addr   := dut.io.{{ instance.port_map.m_aw_addr }}
