    {{ instance.name }}_nasti.b.ready    := dut.io.{{ instance.port_map.m_b_ready }}

    // ── AXI4 read address ─────────────────────────────────────────────────────
    {{ instance.name }}_nasti.ar.valid       := dut.io.{{ instance.port_map.m_ar_valid }}
    {{ instance.name }}_nasti.ar.bits.id     := dut.io.{{ instance.port_map.m_ar_id }}
    {{ instance.name }}_nasti.ar.bits.addr   := dut.io.{{ instance.port_map.m_ar_addr }}
    {{ instance.name }}_nasti.ar.bits.len    := dut.io.{{ instance.port_map.m_ar_len }}
    {{ instance.name }}_nasti.ar.bits.size   := dut.io.{{ instance.port_map.m_ar_size }}
    {{ instance.name }}_nasti.ar.bits.burst  := dut.io.{{ instance.port_map.m_ar_burst }}
