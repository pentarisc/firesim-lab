    {{ instance.name }}_nasti.aw.bits.qos    := dut.io.{{ instance.port_map.m_aw_qos }}
    {{ instance.name }}_nasti.aw.bits.user   := DontCare
    {{ instance.name }}_nasti.aw.bits.region := 0.U
    dut.io.{{ instance.port_map.s_aw_ready  }} := {{ instance.name }}_nasti.aw.ready

    // ── AXI4 write data ───────────────────────────────────────────────────────
    {{ instance.name }}_nasti.w.valid     := dut.io.{{ instance.port_map.m_w_valid }}
    {{ instance.name }}_nasti.w.bits.data := dut.io.{{ instance.port_map.m_w_data }}
    {{ instance.name }}_nasti.w.bits.strb := dut.io.{{ instance.port_map.m_w_strb }}
    {{ instance.name }}_nasti.w.bits.last := dut.io.{{ instance.port_map.m_w_last }}
    {{ instance.name }}_nasti.w.bits.user := DontCare
    {{ instance.name }}_nasti.w.bits.id   := DontCare // We only use AXI4, not AXI3
    dut.io.{{ instance.port_map.s_w_ready }} := {{ instance.name }}_nasti.w.ready

    // ── AXI4 write response ───────────────────────────────────────────────────
    dut.io.{{ instance.port_map.s_b_valid }}     := {{ instance.name }}_nasti.b.valid
    dut.io.{{ instance.port_map.s_b_id }}   := {{ instance.name }}_nasti.b.bits.id
