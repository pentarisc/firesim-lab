    dut.io.{{ instance.port_map.s_r_resp }} := {{ instance.name }}_nasti.r.bits.resp
    dut.io.{{ instance.port_map.s_r_last }} := {{ instance.name }}_nasti.r.bits.last
    dut.io.{{ instance.port_map.s_r_user }} := DontCare
    {{ instance.name }}_nasti.r.ready    := dut.io.{{ instance.port_map.m_r_ready }}

    FASEDBridge(clock, {{ instance.name }}_nasti, reset.asBool,
      CompleteConfig(
        {{ instance.name }}_nastiKey,
        Some(AXI4EdgeSummary.createCompatEdgeSummary(edge)),
        Some("{{ instance.params.memory_region_name.value }}"),
      )
