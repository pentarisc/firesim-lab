"# =============================================================================
# Makefile.{{ sim.id }}.sim  --  {{ sim.label }}
# Auto-generated by CMake. Do not edit by hand.
# =============================================================================

# -- Paths (resolved by CMake at configure-time) ------------------------------
midas_dir     := ${MIDAS_DIR}
fslab_include := ${FSLAB_BRIDGES_DIR}/src/main/cc
v_dir         := ${V_DIR}
