    COMMAND ${CMAKE_MAKE_PROGRAM} -f "Makefile.{{ sim.id }}.sim" {{ tgt.make_target if tgt.make_target else tgt.name }}
    WORKING_DIRECTORY "${METASIM_BUILD_DIR}"
    COMMENT "{{ tgt.comment if tgt.comment else '[fslab] ' ~ sim.label ~ ': ' ~ tgt.name }}"
    VERBATIM
)
{% endfor %}

{% if sim.cmake_fragment %}
# -- cmake_fragment for {{ sim.id }} (verbatim from registry.yaml) --
{{ sim.cmake_fragment }}
