sim_wrapper_v  := \$(v_dir)/top.sv
verilator_conf := \$(midas_dir)/rtlsim/ml-verilator-conf.vlt
sim_harness    := \$(midas_dir)/simif_emul_all.cc

# -- Tool-specific Makefrag includes and target aliases -----------------------
# Source: registry.yaml metasimulators.{{ sim.id }}.makefile_fragment
{{ sim.makefile_fragment }}
")

# cmake custom targets — one per variant in cmake_targets.
# cmake target: metasim-<name>   make target: <make_target or name>
