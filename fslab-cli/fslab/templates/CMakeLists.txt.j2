{#
  CMakeLists.txt.j2
  =================
  Jinja2 template for the host-driver CMake build.
  Generated by fslab — do not edit by hand.

  Design principles
  -----------------
  - PLATFORM-AGNOSTIC / TOOL-AGNOSTIC: zero platform or simulator names are
    hard-coded here. All knowledge lives in registry.yaml entries.
  - Four independent build sub-trees, each with its own output directory:
      build/driver/    - real FPGA host driver  (fslab build driver)
      build/metasim/   - SW meta-simulators     (fslab build metasim --tool X)
      build/fpgasim/   - FPGA meta-simulators   (fslab build fpgasim --tool X)
      build/fpga/      - FPGA bitstream staging (fslab build fpga / fslab bitstream)
  - $ENV{VAR} syntax is used for CMake sections (Decision 3a); $(VAR) Makefile
    syntax is used inside file(WRITE) blocks (expanded by Make at build time).
  - cmake_fragment / makefile_fragment are escape hatches for constructs the
    structured schema fields cannot yet express.

  Escaping inside file(WRITE) blocks
  -----------------------------------
  - ${CMAKE_VAR}   -> cmake expands at configure time            (intended)
  - \$(make_var)   -> cmake passes through; Make expands at build time
  - $$$$ORIGIN     -> cmake writes $$$$ORIGIN; Make assignment sees $$$$->$$;
                      recipe re-expands $$->$; shell sees -Wl,-rpath='$ORIGIN'
                      inside single quotes; linker gets $ORIGIN. ✓

  Context variables
  -----------------
  Core
    project_name        str
    platform            str        (informational; section 4b uses platform_cfg)
    driver_name         str
    gen_dir             str
    gen_file_basename   str
    clock_period        str
    firesim_root        str
    firesim_lab_root    str
    platforms_root      str
    quintuplet          str        {project_name}-{platform}; unique build identifier

  Compiler
    cxx_standard        int
    cxx_flags           list[str]
    driver_cxxopts      list[str]  (default: ["-O2"])
    link_libs           list[str]  (common libs; pthread, gmp, rt, stdc++ appended)

  Sources
    user_cc_files       list[str]
    user_h_files        list[str]
    fslab_bridge_cc_files     list[str]
    fslab_bridge_h_files      list[str]
    custom_bridge_cc_files     list[str]
    custom_bridge_h_files      list[str]

  Platform (sections 4, 4b and 8)
    platform_cfg                   Resolved PlatformEntry from registry
      .rpath_origin     bool
      .required_env_vars list[str]
      .extra_cxx_flags  list[str]
      .extra_include_dirs list[str]   CMake-style paths ($ENV{VAR} / ${VAR} / /)
      .extra_link_dirs  list[str]
      .extra_libs       list[str]
      .extra_link_options list[str]
      .cmake_fragment   str
      .board_dir        str        Path to platform board template base directory.
                                   CMake-style ${VAR} refs ok. Written into
                                   Makefile.fpga.mk as a reference variable for the
                                   BitBuilder; not used in any local build recipe.
      .fpga_delivery_exts list[str] File extensions staged into
                                   build/fpga/cl_<quintuplet>/design/
                                   e.g. [".sv", ".defines.vh", ".synthesis.xdc", ...]

  Meta-simulators (section 5)
    metasim_cfg         Resolved MetaSimEntry from registry
      Each entry:
      .id               str        e.g. verilator / vcs / xcelium
      .label            str
      .tool_cxxopts     list[str]  VERILATOR_CXXOPTS / VCS_CXXOPTS / etc. (default ["-O2"])
      .rtlsim_define    bool       Add -D RTLSIM to CXXFLAGS (true for all SW metasim)
      .rpath_origin     bool
      .required_env_vars list[str]
      .extra_cxx_flags  list[str]  Makefile-style flags
      .extra_include_dirs list[str] Makefile-style paths: $(VAR) or /
      .extra_link_dirs  list[str]
      .extra_libs       list[str]  Bare names, no -l prefix
      .extra_link_options list[str] Raw linker flags; placed BEFORE libs (--no-as-needed)
      .cmake_targets    list[SimTarget]
          .name         str        Suffix for cmake "metasim-<n>" AND make target name
          .make_target  str        Override make target if different from .name
          .comment      str
      .cmake_fragment   str
      .makefile_fragment str       Verbatim Makefile content appended to Makefile.<id>.sim
                                   (Makefrag includes and target aliases go here)

  FPGA meta-simulators (section 6)
    fpgasim_cfg         Resolved FpgaSimEntry from registry
      Each entry:
      .id               str        e.g. xsim
      .label            str
      .main             str        MAIN= arg (e.g. "f2_xsim")
      .platform_override str       PLATFORM= override (e.g. "f2")
      .rpath_origin     bool
      .required_env_vars list[str]
      .extra_cxx_flags  list[str]  Makefile-style
      .extra_include_dirs list[str] Makefile-style paths
      .extra_link_dirs  list[str]
      .extra_libs       list[str]
      .extra_link_options list[str]
      .cmake_targets    list[SimTarget]
      .cmake_fragment   str
      .makefile_fragment str
