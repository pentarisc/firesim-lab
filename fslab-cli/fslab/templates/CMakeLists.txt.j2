LDFLAGS :={% for opt in sim.extra_link_options %} {{ opt }}{% endfor %} -L\$(GEN_DIR){% for lib in link_libs %} -l{{ lib }}{% endfor %}{% if sim.rpath_origin %} -Wl,-rpath='$$$$ORIGIN'{% endif %}{% for d in sim.extra_link_dirs %} -L{{ d }}{% endfor %}{% for lib in sim.extra_libs %} -l{{ lib }}{% endfor %}

