# ==============================================================================
# CMakeLists.txt
# @GENERATED_BY_FSLAB  platform={{ platform }}
# Warning: This file is auto-generated. Manual edits will be overwritten on
# the next `fslab generate` run.
# ==============================================================================

cmake_minimum_required(VERSION 3.15)
project({{ project_name }} CXX)

# ------------------------------------------------------------------------------
# 1. Environment & Path Variables
# ------------------------------------------------------------------------------
set(PLATFORM          "{{ platform }}"          CACHE STRING "Target FPGA Platform")
set(DRIVER_NAME       "{{ driver_name }}"       CACHE STRING "Base name for drivers")
set(GEN_FILE_BASENAME "{{ gen_file_basename }}" CACHE STRING "GoldenGate generated basename")
set(CLOCK_PERIOD      "{{ clock_period }}"      CACHE STRING "Simulation Clock Period")
set(PROJECT_DIR       "{{ project_dir }}"       CACHE STRING "Project directory")

set(FIRESIM_ROOT      "{{ firesim_root }}"      CACHE PATH "Path to FireSim")
set(FIRESIM_LAB_ROOT  "{{ firesim_lab_root }}"  CACHE PATH "Path to FireSim Lab Bridges")
set(PLATFORMS_ROOT    "{{ platforms_root }}"    CACHE PATH "Path to FireSim Platforms directory")
set(GEN_DIR "${CMAKE_CURRENT_SOURCE_DIR}/{{ gen_dir }}" CACHE PATH "Generated RTL/Headers directory")
set(V_DIR   "${FIRESIM_ROOT}/sim/midas/src/main/verilog"       CACHE PATH "Static Verilog directory")
set(MIDAS_DIR         "${FIRESIM_ROOT}/sim/midas/src/main/cc" CACHE PATH "midas c++ sources")
set(FSLAB_BRIDGES_DIR "${FIRESIM_LAB_ROOT}/lib/bridges"       CACHE PATH "firesim-lab bridge sources")

# Build sub-directories — one per top-level target class.
# These are created at configure-time so sub-make can write into them immediately.
set(DRIVER_BUILD_DIR  "${CMAKE_BINARY_DIR}/driver"  CACHE PATH "Driver build output")
set(METASIM_BUILD_DIR "${CMAKE_BINARY_DIR}/metasim" CACHE PATH "Metasim build output")
set(FPGASIM_BUILD_DIR "${CMAKE_BINARY_DIR}/fpgasim" CACHE PATH "FPGASim build output")

file(MAKE_DIRECTORY "${DRIVER_BUILD_DIR}")
file(MAKE_DIRECTORY "${METASIM_BUILD_DIR}")
file(MAKE_DIRECTORY "${FPGASIM_BUILD_DIR}")

set(FPGA_BUILD_DIR "${CMAKE_BINARY_DIR}/fpga"  CACHE PATH   "FPGA staging build output")
set(QUINTUPLET     "{{ quintuplet }}"           CACHE STRING "Project-platform identifier")
file(MAKE_DIRECTORY "${FPGA_BUILD_DIR}")

# ------------------------------------------------------------------------------
# 2. Global C++ Flags
# ------------------------------------------------------------------------------
set(CMAKE_CXX_STANDARD {{ cxx_standard }})
set(CMAKE_CXX_STANDARD_REQUIRED ON)
{% if cxx_flags %}
add_compile_options(
{% for flag in cxx_flags %}
    {{ flag }}
{% endfor %}
)
{% endif %}

# ------------------------------------------------------------------------------
# 3. Gather Source Files
# ------------------------------------------------------------------------------

# -- User Project Sources --
set(USER_CC
{% for src in user_cc_files %}
    ${CMAKE_CURRENT_SOURCE_DIR}/{{ src }}
{% endfor %}
)
set(USER_H
{% for src in user_h_files %}
    ${CMAKE_CURRENT_SOURCE_DIR}/{{ src }}
{% endfor %}
)

# -- Midas Bridge Sources --
file(GLOB MIDAS_BRIDGE_CC CONFIGURE_DEPENDS
    "${MIDAS_DIR}/bridges/*.cc"
    "${MIDAS_DIR}/core/*.cc"
)

file(GLOB MIDAS_BRIDGE_H  CONFIGURE_DEPENDS
    "${MIDAS_DIR}/bridges/*.h"
    "${MIDAS_DIR}/core/*.h"
)

# -- Firesim-lab core sources
file(GLOB FSLAB_CORE_CC CONFIGURE_DEPENDS
    "${FSLAB_BRIDGES_DIR}/src/main/cc/*.cc"
    "${FSLAB_BRIDGES_DIR}/src/main/cc/sim/*.cc"
)

file(GLOB FSLAB_CORE_H CONFIGURE_DEPENDS
    "${FSLAB_BRIDGES_DIR}/src/main/cc/*.h"
    "${FSLAB_BRIDGES_DIR}/src/main/cc/sim/*.h"
)

# -- FireSim-Lab Bridge Sources --
set(BRIDGE_CC
    ${MIDAS_BRIDGE_CC}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/bridges/loadmem_bin.cc
    ${FSLAB_CORE_CC}
{% for src in fslab_bridge_cc_files %}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/{{ src }}
{% endfor %}
{% for src in custom_bridge_cc_files %}
    ${PROJECT_DIR}/src/main/cc/{{ src }}
{% endfor %}
)
set(BRIDGE_H
    ${MIDAS_BRIDGE_H}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/bridges/loadmem_bin.h
    ${FSLAB_CORE_H}
{% for src in fslab_bridge_h_files %}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/{{ src }}
{% endfor %}
{% for src in custom_bridge_h_files %}
    ${PROJECT_DIR}/src/main/cc/{{ src }}
{% endfor %}
)

{% if verilog_files %}
set(DESIGN_RTL
{% for verilog_file in verilog_files %}
  "{{ verilog_file }}"
{% endfor %}
)
{% endif %}

# -- Platform Interface Sources --
set(PLATFORM_CC
    ${MIDAS_DIR}/simif_${PLATFORM}.cc
    ${MIDAS_DIR}/main.cc
    ${MIDAS_DIR}/entry.cc
)

# Space-separated strings for Makefile.sim consumption (sections 5 and 6).
string(REPLACE ";" " " MAKE_USER_CC   "${USER_CC}")
string(REPLACE ";" " " MAKE_USER_H    "${USER_H}")
string(REPLACE ";" " " MAKE_BRIDGE_CC "${BRIDGE_CC}")
string(REPLACE ";" " " MAKE_BRIDGE_H  "${BRIDGE_H}")
string(REPLACE ";" " " MAKE_DESIGN_RTL  "${DESIGN_RTL}")

# ------------------------------------------------------------------------------
# 4. Target: Host Software Driver  ->  build/driver/
# ------------------------------------------------------------------------------
set(DRIVER_TARGET "${DRIVER_NAME}-${PLATFORM}")

add_executable(${DRIVER_TARGET}
    ${BRIDGE_CC}
    ${USER_CC}
    ${PLATFORM_CC}
)

# Route the driver binary into its own clean sub-directory.
set_target_properties(${DRIVER_TARGET} PROPERTIES
    RUNTIME_OUTPUT_DIRECTORY "${DRIVER_BUILD_DIR}"
)

target_include_directories(${DRIVER_TARGET} PRIVATE
    ${FIRESIM_ROOT}/sim/src/main/cc
    ${MIDAS_DIR}
    ${FSLAB_BRIDGES_DIR}/src/main/cc
    ${GEN_DIR}
    ${CMAKE_CURRENT_SOURCE_DIR}/include
)

# Common libraries (pthread, gmp, rt, stdc++ appended by context.py _SYSTEM_LIBS)
target_link_libraries(${DRIVER_TARGET} PRIVATE
{% for lib in link_libs %}
    {{ lib }}
{% endfor %}
)

target_link_directories(${DRIVER_TARGET} PRIVATE
    ${GEN_DIR}
)

# Convenience alias: cmake --build build/ --target driver
add_custom_target(driver DEPENDS ${DRIVER_TARGET})

# ------------------------------------------------------------------------------
# 4b. Platform-Specific Driver Configuration
#
#     All values come exclusively from registry.yaml platforms.{{ platform }}.
#     This block is a pure structural renderer — no platform names or SDK paths
#     are hard-coded here. To add a new platform, add a registry.yaml entry only.
# ------------------------------------------------------------------------------

# Per-driver optimisation flags  (mirrors DRIVER_CXXOPTS ?= -O2 in driver.mk)
{% if driver_cxxopts %}
target_compile_options(${DRIVER_TARGET} PRIVATE
{% for opt in driver_cxxopts %}
    "{{ opt }}"
{% endfor %}
)
{% endif %}

{% if platform_cfg.required_env_vars %}
# Validate required environment variables at cmake configure-time.
# $ENV{} emitted verbatim (Decision 3a); CMake resolves at configure-time.
{% for var in platform_cfg.required_env_vars %}
if("$ENV{ {{- var -}} }" STREQUAL "")
    message(FATAL_ERROR
        "[fslab] Platform '${PLATFORM}' requires the {{ var }} environment variable.\n"
        "       Set it before running cmake.")
endif()
{% endfor %}

{% endif %}
{% if platform_cfg.rpath_origin %}
# $ORIGIN rpath — shared libs are co-located with the driver on the run-host.
# $ORIGIN is an ELF loader token; no cmake/shell escaping is needed here.
target_link_options(${DRIVER_TARGET} PRIVATE "-Wl,-rpath,$ORIGIN")

{% endif %}
{% if platform_cfg.extra_cxx_flags %}
target_compile_options(${DRIVER_TARGET} PRIVATE
{% for flag in platform_cfg.extra_cxx_flags %}
    "{{ flag }}"
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_include_dirs %}
# Paths may contain ${CMAKE_VAR} or $ENV{VAR} references (Decision 3a).
target_include_directories(${DRIVER_TARGET} PRIVATE
{% for d in platform_cfg.extra_include_dirs %}
    {{ d }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_link_dirs %}
target_link_directories(${DRIVER_TARGET} PRIVATE
{% for d in platform_cfg.extra_link_dirs %}
    {{ d }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_libs %}
target_link_libraries(${DRIVER_TARGET} PRIVATE
{% for lib in platform_cfg.extra_libs %}
    {{ lib }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_link_options %}
target_link_options(${DRIVER_TARGET} PRIVATE
{% for opt in platform_cfg.extra_link_options %}
    "{{ opt }}"
{% endfor %}
)

{% endif %}
{% if platform_cfg.cmake_fragment %}
# -- cmake_fragment: verbatim CMake from registry.yaml (escape hatch) ---------
{{ platform_cfg.cmake_fragment }}
# -- end cmake_fragment -------------------------------------------------------
{% endif %}

