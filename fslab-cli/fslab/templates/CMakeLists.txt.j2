OUT_DIR       := ${METASIM_BUILD_DIR}
PLATFORM      := ${PLATFORM}
DRIVER_NAME   := ${DRIVER_NAME}
CLOCK_PERIOD  := ${CLOCK_PERIOD}

# FireSim variable-name compatibility aliases
