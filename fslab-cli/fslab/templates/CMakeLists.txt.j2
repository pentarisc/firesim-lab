# ==============================================================================
# 8. Target: FPGA Bitstream Staging  ->  build/fpga/
#
#    Generates Makefile.fpga.mk which stages the generated RTL and compiled
#    driver binary into a self-contained local directory:
#
#      build/fpga/cl_<quintuplet>/
#          design/   <- RTL delivery files + build_info
#          driver/   <- compiled driver binary
#
#    This directory contains ONLY project-generated artifacts — no platform SDK
#    content, no symlinks.  It is the sole rsync payload for the BitBuilder.
#    The BitBuilder is responsible for setting up the full in-tree cl_<quintuplet>
#    on the remote (cp -rf board_dir/cl_firesim, platform symlinks, etc.) before
#    overlaying the rsynced files.  CMake's responsibility ends at local staging;
#    the remote bitstream build is orchestrated separately by 'fslab bitstream'.
#
#    board_dir is written into Makefile.fpga.mk as a reference variable so the
#    BitBuilder can read it without consulting registry.yaml directly.
#
#    All platform-specific values come exclusively from registry.yaml
#    platforms.{{ platform }}.  No platform names are hard-coded here.
#
#    Available cmake targets after generation:
#      fpga-replace-rtl  -- stage RTL + driver into build/fpga/cl_<quintuplet>/
#                           (depends on driver target; also stages build_info)
#      fpga-clean        -- remove build/fpga/cl_<quintuplet>/
#      fpga              -- top-level alias for fpga-replace-rtl
# ==============================================================================
{% if platform_cfg.board_dir %}

file(WRITE "${FPGA_BUILD_DIR}/Makefile.fpga.mk"
"# =============================================================================
# Makefile.fpga.mk
# Auto-generated by CMake. Do not edit by hand.
# =============================================================================

# -- Paths (resolved by CMake at configure-time) ------------------------------
platforms_dir     := ${PLATFORMS_ROOT}
midas_dir         := ${MIDAS_DIR}
GEN_DIR           := ${GEN_DIR}
OUT_DIR           := ${FPGA_BUILD_DIR}
PLATFORM          := ${PLATFORM}
DRIVER_NAME       := ${DRIVER_NAME}
GEN_FILE_BASENAME := ${GEN_FILE_BASENAME}
QUINTUPLET        := ${QUINTUPLET}

# -- FireSim variable compatibility aliases -----------------------------------
BASE_FILE_NAME    := \$(GEN_FILE_BASENAME)
DESIGN            := \$(DRIVER_NAME)

# -- Board / work directories -------------------------------------------------
# board_dir: from registry.yaml — reference for BitBuilder; not used locally.
# fpga_work_dir: local staging tree, fully within the project build directory.
board_dir         := {{ platform_cfg.board_dir }}
fpga_work_dir     := ${FPGA_BUILD_DIR}/cl_${QUINTUPLET}
fpga_build_dir    := \$(fpga_work_dir)/build
verif_dir         := \$(fpga_work_dir)/verif
fpga_driver_dir   := \$(fpga_work_dir)/driver
fpga_delivery_dir := \$(fpga_work_dir)/design

# -- Delivery files (extensions from registry.yaml platform entry) ------------
fpga_delivery_files = \$(addprefix \$(fpga_delivery_dir)/\$(BASE_FILE_NAME),{% for ext in platform_cfg.fpga_delivery_exts %} {{ ext }}{% endfor %})

# -- Driver binary (path fully resolved by CMake at configure-time) -----------
DRIVER_BINARY           := ${DRIVER_BUILD_DIR}/${DRIVER_NAME}-${PLATFORM}
fpga_sim_delivery_files := \$(fpga_driver_dir)/\$(DRIVER_NAME)-\$(PLATFORM)

# -- build_info source (written by CMake at configure-time; survives cleanfpga)
BUILD_INFO_SRC    := ${FPGA_BUILD_DIR}/build_info

# -- Stamp: create local staging directories ----------------------------------
# No platform SDK content is copied here. The BitBuilder is responsible for
# setting up the full in-tree cl_<quintuplet> on the remote (template copy,
# platform symlinks, etc.) before overlaying the rsynced payload.
\$(fpga_work_dir)/stamp:
\tmkdir -p \$(fpga_delivery_dir)
\tmkdir -p \$(fpga_driver_dir)
\ttouch \$@

# -- RTL delivery files -------------------------------------------------------
\$(fpga_delivery_dir)/\$(BASE_FILE_NAME)%: \$(fpga_work_dir)/stamp
\tcp -f \$(GEN_DIR)/*.ipgen.tcl \$(@D) || true
\tcp -f \$(GEN_DIR)/\$(@F) \$@

# -- Driver binary delivery ---------------------------------------------------
# Order-only dep on stamp ensures staging dirs exist; no rebuild if stamp newer.
\$(fpga_driver_dir)/\$(DRIVER_NAME)-\$(PLATFORM): \$(DRIVER_BINARY) | \$(fpga_work_dir)/stamp
\tcp -f \$< \$@

# -- build_info: provenance file staged alongside RTL for remote rsync --------
\$(fpga_delivery_dir)/build_info: \$(BUILD_INFO_SRC) | \$(fpga_work_dir)/stamp
\tcp -f \$< \$@

# -- User RTL sources (Verilog blackboxes instantiated by the generated top SV)
# Copied alongside the generated .sv so Vivado sees a complete source set.
{% if verilog_files %}
DESIGN_RTL := ${MAKE_DESIGN_RTL}

# -- User RTL delivery ---------------------------------------------------------
\$(fpga_delivery_dir)/.rtl_stamp: \$(DESIGN_RTL) | \$(fpga_work_dir)/stamp
\tcp -f \$(DESIGN_RTL) \$(fpga_delivery_dir)/
\ttouch \$@
{% endif %}

# -- replace-rtl: stage all deliverables for remote rsync --------------------
.PHONY: replace-rtl
replace-rtl: \$(fpga_delivery_files) \$(fpga_sim_delivery_files) \
             \$(fpga_delivery_dir)/build_info{% if verilog_files %} \$(fpga_delivery_dir)/.rtl_stamp{% endif %}

{% if platform_cfg.makefile_fragment %}
# -- makefile_fragment: verbatim Makefile content from registry.yaml ----------
{{ platform_cfg.makefile_fragment }}
# -- end makefile_fragment ----------------------------------------------------
{% endif %}

# -- cleanfpga ----------------------------------------------------------------
.PHONY: cleanfpga
cleanfpga:
\trm -rf \$(fpga_work_dir)
")

# build_info is written at configure-time so it survives cleanfpga and is
# always present as a reference even before a build has been attempted.
# It is copied into design/ by the build_info make target during replace-rtl.
string(TIMESTAMP FSLAB_BUILD_TIMESTAMP UTC)
file(WRITE "${FPGA_BUILD_DIR}/build_info"
"project:    ${PROJECT_NAME}
quintuplet: ${QUINTUPLET}
platform:   ${PLATFORM}
driver:     ${DRIVER_NAME}-${PLATFORM}  (binary in driver/)
generated:  ${FSLAB_BUILD_TIMESTAMP} UTC

For manual deployment steps, refer to the documentation.
")

add_custom_target(fpga-replace-rtl
    COMMAND ${CMAKE_MAKE_PROGRAM} -f "Makefile.fpga.mk" replace-rtl
    WORKING_DIRECTORY "${FPGA_BUILD_DIR}"
    DEPENDS ${DRIVER_TARGET}
    COMMENT "[fslab] Staging RTL and driver into FPGA work directory"
    VERBATIM
)

add_custom_target(fpga-clean
    COMMAND ${CMAKE_MAKE_PROGRAM} -f "Makefile.fpga.mk" cleanfpga
    WORKING_DIRECTORY "${FPGA_BUILD_DIR}"
    COMMENT "[fslab] Cleaning FPGA work directory"
    VERBATIM
)

# Top-level alias: cmake --build build/ --target fpga
# CMake's responsibility ends here — remote bitstream build is handled by
# python code that runs this target 'fslab build fpga'.
add_custom_target(fpga
    DEPENDS fpga-replace-rtl
    COMMENT "[fslab] FPGA staging complete — remote build will be triggered for bitstream generation."
)

{% endif %}