emul_dir := \$(midas_dir)/emul

emul_cc := ${MAKE_USER_CC} ${MAKE_BRIDGE_CC} \$(emul_dir)/simif_emul.cc \$(emul_dir)/mmio.cc \$(emul_dir)/mm.cc \$(emul_dir)/dpi.cc \$(midas_dir)/entry.cc \$(emul_dir)/qsfp.cc
