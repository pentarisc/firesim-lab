CXX := ${CMAKE_CXX_COMPILER}

# CXXFLAGS: global flags + RTLSIM define + tool_cxxopts + extra_cxx_flags
#           + midas/gen includes + extra_include_dirs  (Makefile \$(VAR) style)
CXXFLAGS := -std=c++{{ cxx_standard }}{% for f in cxx_flags %} {{ f }}{% endfor %}{% if sim.rtlsim_define %} -D RTLSIM{% endif %}{% for opt in sim.tool_cxxopts %} {{ opt }}{% endfor %}{% for f in sim.extra_cxx_flags %} {{ f }}{% endfor %} -I\$(midas_dir) -I\$(fslab_include) -I\$(GEN_DIR){% for d in sim.extra_include_dirs %} -I{{ d }}{% endfor %}

