{#
  CMakeLists.txt.j2
  =================
  Jinja2 template for the host-driver CMake build.
  Generated by fslab — do not edit by hand.

  Design principles
  -----------------
  - This template is PLATFORM-AGNOSTIC. It contains zero platform names, zero
    platform-specific paths, and zero platform-specific logic. All platform
    knowledge lives exclusively in registry.yaml under platforms.<name>.
  - Adding a new FPGA platform requires only a new registry.yaml entry —
    this file never changes.
  - Environment variable references use CMake $ENV{VAR} syntax (Decision 3a).
    They are emitted verbatim; CMake resolves them at configure-time. This is
    intentional: runtime env vars (EDA license servers, XRT paths, etc.) must
    NOT be baked in at generation time.
  - cmake_fragment is the escape hatch (Decision 1, Option 1): any CMake
    construct that cannot be expressed through structured fields can be placed
    there verbatim. When a pattern recurs across platforms, promote it to a
    structured field in the next CLI release.

  Context variables (all produced by _build_template_context)
  -----------------------------------------------------------
  Core
    project_name        str        project.name
    platform            str        target.platform  (display / informational only)
    driver_name         str        host.driver_name
    gen_dir             str        advanced.gen_dir
    gen_file_basename   str        advanced.gen_file_basename
    clock_period        str        target.clock_period
    firesim_root        str        advanced.firesim_root
    firesim_lab_root    str        advanced.firesim_lab_root
    platforms_dir       str        advanced.platforms_dir
                                   (default: firesim_root + "/../platforms")

  Compiler
    cxx_standard        int        host.cxx_standard
    cxx_flags           list[str]  host.cxx_flags, split into individual flags
    driver_cxxopts      list[str]  host.driver_cxxopts (default: ["-O2"])
                                   Applied uniformly to all platforms.
    link_libs           list[str]  host.libs merged with required system libs.
                                   pthread, gmp, rt, stdc++ always appended.

  Sources
    user_cc_files       list[str]  host.sources
    user_h_files        list[str]  host.includes
    bridge_cc_files     list[str]  cpp_sources from every bridge, de-duplicated
    bridge_h_files      list[str]  cpp_headers from every bridge, de-duplicated

  Platform (resolved from registry.yaml by the CLI — template never inspects these)
    platform_cfg                   Resolved platform config object
      .rpath_origin     bool       Embed $ORIGIN in rpath (runtime shared lib search)
      .required_env_vars list[str] Checked at cmake-configure time; FATAL_ERROR if absent
      .extra_cxx_flags  list[str]  Platform-specific compile flags
      .extra_include_dirs list[str] Platform-specific include paths.
                                   Supports CMake vars (${VAR}) and env refs ($ENV{VAR}).
      .extra_link_dirs  list[str]  Platform-specific linker search paths.
                                   Supports CMake vars and env refs.
      .extra_libs       list[str]  Platform-specific libraries (names only, no -l prefix)
      .extra_link_options list[str] Raw platform-specific linker flags
      .cmake_fragment   str        Verbatim CMake injected last in section 4b.
                                   Escape hatch for constructs not covered by structured fields.
                                   Jinja2 context variables are available inside the fragment.
#}
# ==============================================================================
# CMakeLists.txt
# @GENERATED_BY_FSLAB  platform={{ platform }}
# Warning: This file is auto-generated by the fslab CLI. Manual edits will be
# overwritten on the next `fslab generate` run.
# ==============================================================================

cmake_minimum_required(VERSION 3.15)
project({{ project_name }} CXX)

# ------------------------------------------------------------------------------
# 1. Environment & Path Variables
# ------------------------------------------------------------------------------
set(PLATFORM          "{{ platform }}"          CACHE STRING "Target FPGA Platform")
set(DRIVER_NAME       "{{ driver_name }}"       CACHE STRING "Base name for drivers")
set(GEN_FILE_BASENAME "{{ gen_file_basename }}" CACHE STRING "GoldenGate generated basename")
set(CLOCK_PERIOD      "{{ clock_period }}"      CACHE STRING "Simulation Clock Period")

set(FIRESIM_ROOT      "{{ firesim_root }}"      CACHE PATH "Path to FireSim")
set(FIRESIM_LAB_ROOT  "{{ firesim_lab_root }}"  CACHE PATH "Path to FireSim Lab Bridges")
set(PLATFORMS_DIR     "${FIRESIM_ROOT}/platforms"     CACHE PATH "Path to FireSim Platforms directory")
set(GEN_DIR "${CMAKE_CURRENT_SOURCE_DIR}/{{ gen_dir }}" CACHE PATH "Directory for generated RTL/Headers")
set(OUT_DIR "${CMAKE_CURRENT_BINARY_DIR}"               CACHE PATH "Directory for output binaries")
set(V_DIR   "${CMAKE_CURRENT_SOURCE_DIR}/verilog"       CACHE PATH "Directory for static Verilog files")
set(MIDAS_DIR         "${FIRESIM_ROOT}/sim/midas/src/main/cc" CACHE PATH "Directory for midas c++ sources")
set(FSLAB_BRIDGES_DIR "${FIRESIM_LAB_ROOT}/lib/bridges"       CACHE PATH "Directory for firesim-lab c++ bridge sources")

# ------------------------------------------------------------------------------
# 2. Global C++ Flags
# ------------------------------------------------------------------------------
set(CMAKE_CXX_STANDARD {{ cxx_standard }})
set(CMAKE_CXX_STANDARD_REQUIRED ON)
{% if cxx_flags %}
add_compile_options(
{% for flag in cxx_flags %}
    {{ flag }}
{% endfor %}
)
{% endif %}

# ------------------------------------------------------------------------------
# 3. Gather Source Files (Injected via Jinja2 from YAML)
# ------------------------------------------------------------------------------

# -- User Project Sources --
set(USER_CC
{% for src in user_cc_files %}
    ${CMAKE_CURRENT_SOURCE_DIR}/{{ src }}
{% endfor %}
)
set(USER_H
{% for src in user_h_files %}
    ${CMAKE_CURRENT_SOURCE_DIR}/{{ src }}
{% endfor %}
)

# -- Midas Bridge Sources --
file(GLOB MIDAS_BRIDGE_CC CONFIGURE_DEPENDS
    "${MIDAS_DIR}/bridges/*.cc"
    "${MIDAS_DIR}/core/*.cc"
)

file(GLOB MIDAS_BRIDGE_H  CONFIGURE_DEPENDS
    "${MIDAS_DIR}/bridges/*.h"
    "${MIDAS_DIR}/core/*.h"
)

# -- FireSim-Lab Bridge Sources --
set(BRIDGE_CC
    ${MIDAS_BRIDGE_CC}
{% for src in bridge_cc_files %}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/{{ src }}
{% endfor %}
)
set(BRIDGE_H
    ${MIDAS_BRIDGE_H}
{% for src in bridge_h_files %}
    ${FSLAB_BRIDGES_DIR}/src/main/cc/{{ src }}
{% endfor %}
)

# -- Platform Interface Sources (simif_<platform>.cc + entry points) --
set(PLATFORM_CC
    ${MIDAS_DIR}/simif_${PLATFORM}.cc
    ${MIDAS_DIR}/main.cc
    ${MIDAS_DIR}/entry.cc
)

# ------------------------------------------------------------------------------
# 4. Target: Host Software Driver
# ------------------------------------------------------------------------------
set(DRIVER_TARGET "${DRIVER_NAME}-${PLATFORM}")

add_executable(${DRIVER_TARGET}
    ${BRIDGE_CC}
    ${USER_CC}
    ${PLATFORM_CC}
)

# Base include paths common to every platform
target_include_directories(${DRIVER_TARGET} PRIVATE
    ${FIRESIM_ROOT}/sim/src/main/cc
    ${MIDAS_DIR}
    ${FSLAB_BRIDGES_DIR}/src/main/cc
    ${GEN_DIR}
    ${CMAKE_CURRENT_SOURCE_DIR}/include
)

# Base libraries common to every platform
# (pthread, gmp, rt, stdc++ are appended by context.py _SYSTEM_LIBS)
target_link_libraries(${DRIVER_TARGET} PRIVATE
{% for lib in link_libs %}
    {{ lib }}
{% endfor %}
)

target_link_directories(${DRIVER_TARGET} PRIVATE
    ${GEN_DIR}
)

# Convenience alias: `cmake --build . --target driver`
add_custom_target(driver DEPENDS ${DRIVER_TARGET})

# ------------------------------------------------------------------------------
# 4b. Platform-Specific Driver Configuration
#
#     ALL values below come exclusively from registry.yaml platforms.{{ platform }}.
#     This section is a pure structural renderer — it contains no platform names,
#     no hard-coded paths, and no conditional logic based on platform identity.
#     To support a new platform, add an entry to registry.yaml only.
# ------------------------------------------------------------------------------

# -- DRIVER_CXXOPTS: per-driver optimisation flags, uniform across platforms --
# Mirrors: DRIVER_CXXOPTS ?= -O2 in driver.mk
{% if driver_cxxopts %}
target_compile_options(${DRIVER_TARGET} PRIVATE
{% for opt in driver_cxxopts %}
    "{{ opt }}"
{% endfor %}
)
{% endif %}

{% if platform_cfg.required_env_vars %}
# -- Validate required environment variables at configure-time --
# Decision 3a: $ENV{} is emitted verbatim; CMake resolves at configure-time.
# This is intentional for values that must not be baked in (license servers, etc.).
{% for var in platform_cfg.required_env_vars %}
if("$ENV{  {{- var -}}  }" STREQUAL "")
    message(FATAL_ERROR
        "[fslab] Platform '${PLATFORM}' requires the {{ var }} environment variable.\n"
        "       Ensure it is set in your environment before running cmake.")
endif()
{% endfor %}

{% endif %}
{% if platform_cfg.rpath_origin %}
# -- $ORIGIN rpath: shared libs are co-located with the driver on the run-host --
# $ORIGIN is an ELF loader token, not a CMake or shell variable — no escaping needed.
# Mirrors: -Wl,-rpath='$$ORIGIN' used across all FPGA platforms in driver.mk.
target_link_options(${DRIVER_TARGET} PRIVATE "-Wl,-rpath,$ORIGIN")

{% endif %}
{% if platform_cfg.extra_cxx_flags %}
# -- Platform-specific compile flags --
target_compile_options(${DRIVER_TARGET} PRIVATE
{% for flag in platform_cfg.extra_cxx_flags %}
    "{{ flag }}"
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_include_dirs %}
# -- Platform-specific include directories --
# Paths may contain ${CMAKE_VAR} or $ENV{VAR} references (Decision 3a).
target_include_directories(${DRIVER_TARGET} PRIVATE
{% for d in platform_cfg.extra_include_dirs %}
    {{ d }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_link_dirs %}
# -- Platform-specific linker search paths --
# Paths may contain ${CMAKE_VAR} or $ENV{VAR} references (Decision 3a).
target_link_directories(${DRIVER_TARGET} PRIVATE
{% for d in platform_cfg.extra_link_dirs %}
    {{ d }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_libs %}
# -- Platform-specific libraries --
target_link_libraries(${DRIVER_TARGET} PRIVATE
{% for lib in platform_cfg.extra_libs %}
    {{ lib }}
{% endfor %}
)

{% endif %}
{% if platform_cfg.extra_link_options %}
# -- Platform-specific raw linker options --
target_link_options(${DRIVER_TARGET} PRIVATE
{% for opt in platform_cfg.extra_link_options %}
    "{{ opt }}"
{% endfor %}
)

{% endif %}
{% if platform_cfg.cmake_fragment %}
# -- cmake_fragment: verbatim CMake from registry.yaml (escape hatch) ----------
# This block is the upgrade path: constructs that cannot yet be expressed
# through structured fields live here. When a pattern recurs across multiple
# platforms, promote it to a structured field in the next CLI release.
{{ platform_cfg.cmake_fragment }}
# -- end cmake_fragment --------------------------------------------------------

{% endif %}
# ------------------------------------------------------------------------------
# 5. Target: Meta-Simulators (Verilator / VCS / Xcelium via FireSim Makefrags)
# ------------------------------------------------------------------------------

# Convert CMake lists to space-separated strings for Make consumption
string(REPLACE ";" " " MAKE_USER_CC   "${USER_CC}")
string(REPLACE ";" " " MAKE_USER_H    "${USER_H}")
string(REPLACE ";" " " MAKE_BRIDGE_CC "${BRIDGE_CC}")
string(REPLACE ";" " " MAKE_BRIDGE_H  "${BRIDGE_H}")

# Write a secondary Makefile that bridges to the FireSim EDA Makefrags.
# Note: simulation flags intentionally do not inherit platform FPGA SDK flags —
# the emulation targets link against the midas emul layer, not the FPGA runtime.
file(WRITE ${CMAKE_CURRENT_BINARY_DIR}/Makefile.sim "
# ==============================================================================
# Auto-generated by CMake — bridges to FireSim EDA Makefrags.
# Do not edit by hand.
# ==============================================================================
midas_dir := ${MIDAS_DIR}
v_dir     := ${V_DIR}
GEN_DIR   := ${GEN_DIR}
OUT_DIR   := ${OUT_DIR}

DRIVER_NAME  := ${DRIVER_NAME}
CLOCK_PERIOD := ${CLOCK_PERIOD}

CXX      := ${CMAKE_CXX_COMPILER}
CXXFLAGS := -std=c++{{ cxx_standard }}{% for flag in cxx_flags %} {{ flag }}{% endfor %} -I\$(midas_dir) -I\$(GEN_DIR)
LDFLAGS  := -L\$(GEN_DIR){% for lib in link_libs %} -l{{ lib }}{% endfor %}

DESIGN_V  := \$(GEN_DIR)/${GEN_FILE_BASENAME}.sv
design_vh := \$(GEN_DIR)/${GEN_FILE_BASENAME}.const.vh
sim_fpga_resource_models := \$(v_dir)/BUFGCE.v

emul_dir := \$(midas_dir)/emul

# Source file variables required by FireSim Makefrags
emul_cc := ${MAKE_USER_CC} ${MAKE_BRIDGE_CC} \$(emul_dir)/simif_emul.cc \$(emul_dir)/mmio.cc \$(emul_dir)/mm.cc \$(emul_dir)/dpi.cc \$(midas_dir)/entry.cc \$(emul_dir)/qsfp.cc
emul_h  := ${MAKE_USER_H}  ${MAKE_BRIDGE_H}  \$(emul_dir)/simif_emul.h  \$(emul_dir)/mmio.h  \$(emul_dir)/mm.h  \$(midas_dir)/entry.h  \$(emul_dir)/qsfp.h
emul_v  := \$(design_vh) \$(DESIGN_V) \$(sim_fpga_resource_models)

TB            := emul
SIM_TIMESCALE := 1ps/1ps
SIM_PREPROC_DEFINES = +define+CLOCK_PERIOD=\$(CLOCK_PERIOD) \\
\t+define+RANDOMIZE_MEM_INIT \\
\t+define+RANDOMIZE_REG_INIT \\
\t+define+RANDOMIZE_GARBAGE_ASSIGN \\
\t+define+RANDOMIZE_INVALID_ASSIGN \\
\t+define+STOP_COND=!\$(TB).reset \\
\t+define+PRINTF_COND=!\$(TB).reset \\
\t+define+RANDOM=32'b0

sim_wrapper_v  := \$(v_dir)/top.sv
sim_harness    := \$(midas_dir)/simif_emul_all.cc
verilator_conf := \$(midas_dir)/rtlsim/ml-verilator-conf.vlt

# EDA tool Makefrags
include \$(midas_dir)/rtlsim/Makefrag-verilator
\$(sim_harness): ;
verilator: \$(OUT_DIR)/V\$(DRIVER_NAME)

include \$(midas_dir)/rtlsim/Makefrag-vcs
\$(vcs_harness): ;
vcs: \$(OUT_DIR)/\$(DRIVER_NAME)

include \$(midas_dir)/rtlsim/Makefrag-xcelium
\$(xcelium_harness): ;
xcelium: \$(xc_sim_name)
")

add_custom_target(verilator
    COMMAND $(MAKE) -f Makefile.sim verilator
    WORKING_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}
    COMMENT "Building Verilator simulation via FireSim Makefrag..."
)

add_custom_target(vcs
    COMMAND $(MAKE) -f Makefile.sim vcs
    WORKING_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}
    COMMENT "Building VCS simulation via FireSim Makefrag..."
)

add_custom_target(xcelium
    COMMAND $(MAKE) -f Makefile.sim xcelium
    WORKING_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}
    COMMENT "Building Xcelium simulation via FireSim Makefrag..."
)

# ------------------------------------------------------------------------------
# 6. Utility Targets
# ------------------------------------------------------------------------------

# tags — regenerate ctags index; mirrors the `tags` target in driver.mk.
find_program(CTAGS_EXECUTABLE ctags)
if(CTAGS_EXECUTABLE)
    add_custom_target(tags
        COMMAND ${CTAGS_EXECUTABLE} -R --exclude=@.ctagsignore .
        WORKING_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR}
        COMMENT "Regenerating ctags index..."
        VERBATIM
    )
else()
    message(STATUS "[fslab] ctags not found — 'tags' target unavailable.")
endif()