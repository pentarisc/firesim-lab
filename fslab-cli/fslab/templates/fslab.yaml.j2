{#
  fslab.yaml.j2
  =============
  Jinja2 template that renders a complete, valid fslab.yaml project file.

  Render with:
      env = jinja2.Environment(
          loader=...,
          trim_blocks=True,
          lstrip_blocks=True,
          keep_trailing_newline=True,
      )
      output = env.get_template("fslab.yaml.j2").render(**ctx)

  Expected context variables
  --------------------------
  project:
    name            str   – e.g. "my_design_02"           [PROJ-01: ^[a-zA-Z0-9_-]+$]
    package_name    str   – e.g. "com.example"            [PROJ-02]
    config_class    str   – e.g. "MyConfig"               [PROJ-02]

  design:
    type            str   – "blackbox" | "chisel"         [PROJ-03]
    parameters      dict  – {NAME: value, …}              (optional, defaults to {})
    sources         list  – RTL source paths              (optional, defaults to [])
    blackbox_ports  dict  – {port: "in|out <width>", …}  (required when type==blackbox)
                                                          [PROJ-05, PROJ-07, PROJ-08]

  target:
    platform        str   – registry platform id          [PROJ-11]
    clock_period    str   – e.g. "1.0"

  host:
    emulator        str   – "verilator" | "vcs" | "xcelium"  [PROJ-04]
    driver_name     str   – e.g. "MyDesign02Driver"
    cxx_standard    int   – 17 | 20 | 23               (default: 17)
    cxx_flags       str   – e.g. "-O3 -Wall"           (default: "")
    sources         list  – C++ source paths            (default: [])
    includes        list  – include directory paths     (default: [])
    libs            list  – linker libraries            (default: [])

  bridges:          list  – zero or more bridge dicts, each with:
    type            str   – registry bridge id          [PROJ-12]
    name            str   – unique instance name        [PROJ-06, PROJ-10]
    port_map        dict  – {bridge_port: bb_port, …}  [PROJ-13]
    params          dict  – {key: value, …}            (optional, defaults to {})

  advanced:                                             (all optional)
    default_registry    str   – path to the firesim-lab registry.yaml
    custom_registries   list  – additional registry paths (last-wins, [REG-07])
    firesim_root        str   – path to FireSim midas directory
    firesim_lab_root    str   – path to firesim-lab bridges library
    gen_dir             str   – output directory for generated files (default: "generated-src")
    gen_file_basename   str   – base filename for generated top  (default: "FSLabTargetTop")
#}
# ==============================================================================
# fslab.yaml — generated by fslab.yaml.j2
# Project : {{ project_name }}
# ==============================================================================

# ------------------------------------------------------------------------------
# project:  Top-level project metadata
#   name          ^[a-zA-Z0-9_-]+$
#   package_name  ^[a-zA-Z_][a-zA-Z0-9_.]*$  (dots OK for packages)
#   config_class  as above
# ------------------------------------------------------------------------------
project:
  name:         "{{ project_name }}"
  package_name: "my.org"
  config_class: "NoConfig"
  project_dir: "{{project_dir}}"

# ------------------------------------------------------------------------------
# target:  FPGA target + build pipeline configuration.
#
# build pipeline shape (4 axes, all nested under target.build:)
#   bitbuilder_args  per-bitbuilder tunables; schema chosen by the platform's
#                    bitbuilder. Most bitbuilders take {} today.
#   host             host-acquisition config; discriminated by host.type.
#                    Today: 'external' (SSH to a pre-provisioned box).
#                    Reserved: 'ec2_launch' (framework-managed EC2).
#   publish          post-build artifact handling; discriminated by publish.type.
#                    Today: 'none', 'local_tarball', 'aws_afi'.
#
# Field defaults are layered:
#   1. fslab framework registry (lib/registry.yaml)
#   2. team / custom registries (target.advanced.custom_registries)
#   3. user value below (final override)
# Required fields with no registry default must be supplied here, or parsing
# fails with a [BBA-XX] / [HMOD-XX] / [PUB-XX] validation error.
# ------------------------------------------------------------------------------
target:
  platform:     "{{ platform }}"
  clock_period: "1.0"
  fpga_sim: "xsim"

  build:
    fpga_frequency: 100.0         # MHz, must satisfy 0 < f <= 300
    build_strategy: "TIMING"      # BASIC|AREA|TIMING|EXPLORE|CONGESTION|NORETIMING|DEFAULT

    # Bitbuilder-specific tunables. The platform selects which bitbuilder
    # runs; the bitbuilder declares the schema for this block. F2 currently
    # has no user-tunables, so {} is the right value.
    bitbuilder_args: {}

    # Host-acquisition config. host.type is the discriminator.
    host:
      type: external
      host: "10.0.0.5"                            # IP or hostname of the build server
      user: "centos"                              # SSH username
      ssh_key: "~/.ssh/firesim.pem"               # null/omit => fall back to ssh-agent or ~/.ssh/config
      remote_platform_path: "/opt/aws-fpga-firesim-f2"   # absolute path to the platform HDK on the build server

    # Post-build artifact handling. publish.type is the discriminator.
    # 'none' is a valid choice (skip publishing entirely; build artifacts
    # remain in the local results dir).
    publish:
      type: none

    # ------------------------------------------------------------------------
    # ALTERNATIVE host examples (uncomment one at a time)
    # ------------------------------------------------------------------------

    # --- AWS-managed EC2 build host (host_model: ec2_launch) ---------------
    # Two sub-modes selected by the presence of `instance_id`:
    #
    #   * instance_id unset → ephemeral. Provider runs RunInstances each
    #     build, waits for SSH, builds, then terminates on release.
    #     Requires ami_id (no vetted default ships today) + instance_type
    #     (defaults via the platform's registry entry).
    #
    #   * instance_id set   → managed reuse. Provider starts the named
    #     instance if stopped, uses it, then stops it on release. If found
    #     running, connection only (leave running on release). HDK upload
    #     is skipped after the first build on this instance — the stamp
    #     file at <remote_platform_path>/.firesim-lab-stamp.yaml tracks
    #     the platform version.
    #
    # aws_profile is the named AWS profile from ~/.aws/config or
    # ~/.aws/credentials; omit/null to fall back to the AWS_PROFILE env
    # var or the [default] profile. Inside the firesim-lab container, the
    # host's ~/.firesim-lab/.aws mounts to ~/.aws — run
    # `aws sso login --profile <name>` (or `aws configure`) once per
    # container to populate it.
    #
    # iam_instance_profile is REQUIRED. The remote build wrapper
    # authenticates to AWS (S3 upload + create-fpga-image) via this EC2
    # instance profile, so hours-long builds are immune to local SSO
    # session expiry. Create the IAM role + instance profile once per
    # AWS account — see docs/aws-setup.md for the exact CLI commands.
    #
    # host:
    #   type: ec2_launch
    #   region: us-west-2
    #   aws_profile: fslab-build                      # optional; null/AWS_PROFILE fallback
    #   iam_instance_profile: fslab-fpga-builder      # REQUIRED — see docs/aws-setup.md
    #   ssh_key: ~/.ssh/fslab_ed25519                 # local private key path (or omit for ssh-agent)
    #   ssh_user: ubuntu                              # default; override for custom AMIs
    #
    #   # --- managed reuse (set instance_id to opt in) ---
    #   # instance_id: i-0abc1234                     # start-if-stopped, stop on release
    #
    #   # --- ephemeral launch (used when instance_id is omitted) ---
    #   lifecycle: spot_one_time                      # spot_one_time | on_demand
    #   ami_id: ami-082c5db2375456e1a                 # required (no vetted default)
    #   key_name: firesim-lab                  # EC2 key-pair name installed at launch
    #   # subnet_id: subnet-xxxxxxxx
    #   # instance_type: m4.4xlarge                   # registry default
    #   # aws_fpga_version: v1.4.0-firesim            # registry default
    #   # remote_platform_path: /home/ubuntu/src/project_data/aws-fpga-firesim-f2

    # ------------------------------------------------------------------------
    # ALTERNATIVE publish examples
    # ------------------------------------------------------------------------

    # --- Local tarball (Alveo / Vitis / on-prem F2) ------------------------
    # publish:
    #   type: local_tarball
    #   output_subdir: built-artifacts        # relative to project_dir; default ok

    # --- AWS AGFI publish (F2 only) ----------------------------------------
    # publish:
    #   type: aws_afi
    #   s3_bucket_name: my-firesim-builds         # required
    #   hwdb_entry_name: "{{ project_name }}_v1"  # default: project.name
    #   # aws_profile: fslab-build                # null/AWS_PROFILE fallback; independent of host.aws_profile
    #   # append_userid_region: true              # registry default; bucket-<userid>-<region>
    #   # copy_to_regions: [us-east-1, us-west-2]
    #   # sns_topic_arn: arn:aws:sns:us-west-2:123456789012:firesim-builds
    #   # post_build_hook: "scripts/notify-team.sh"   # runs with local results dir as $1

  # ----------------------------------------------------------------------------
  # target.run — config for `fslab sim fpga` (FPGA-accelerated simulation).
  # Optional. Omit this block if the project only builds bitstreams.
  #
  # Three orthogonal axes (parallel to target.build):
  #   runner_args      per-runner user tunables (max_cycles, tracing, ...)
  #   host             run-host acquisition; same HostModelConfig as build.host
  #                    (typically an f2.* instance instead of z1d/m4)
  #   artifact_source  where the bitstream comes from (today: aws_afi)
  #
  # IAM note for ec2_launch run hosts: the run host needs a much smaller
  # IAM policy than the build host — only DescribeFpgaImages +
  # AssociateFpgaImage are required so `fpga-load-local-image` can fetch
  # the AGFI manifest and verify entitlement. No S3 write, no
  # CreateFpgaImage. See docs/aws-setup.md for the policy snippet.
  # ----------------------------------------------------------------------------
  # run:
  #   runner_args:
  #     # max_cycles: 1000000                     # optional cycle cap
  #     tracing: false
  #     autocounter: false
  #     # workload_bin: path/to/workload.riscv
  #     extra_driver_flags: []                    # escape hatch for raw +flags
  #
  #   host:
  #     type: ec2_launch
  #     region: us-west-2
  #     aws_profile: fslab-run                    # optional; null/AWS_PROFILE fallback
  #     iam_instance_profile: fslab-fpga-runner   # smaller IAM than build role
  #     ssh_key: ~/.ssh/fslab_ed25519
  #     ssh_user: ubuntu
  #     lifecycle: spot_one_time                  # spot_one_time | on_demand
  #     ami_id: ami-0c0b7a80d5725c332             # FPGA Developer AMI or your own
  #     instance_type: f2.2xlarge                 # FPGA-attached
  #     key_name: firesim-lab
  #     # subnet_id: subnet-xxxxxxxx
  #     # instance_id: i-0abc1234                 # managed reuse instead of ephemeral
  #
  #   artifact_source:
  #     type: aws_afi
  #     agfi: agfi-0123456789abcdef0              # 17 hex chars; from build publish output

## Add your target's design details here. for non-chisel projects, you need to
## specify type as "blackbox" and populate sources and blackbox_ports section.
## The values in the blackbox_ports must match with the port names in your
## top module.
## MANDATORY: This section is mandatory.
{% if top_module and ports -%}
design:
  type: "blackbox"
  top_module: "{{ top_module }}"

  {%- if params %}
  parameters:
  {%- for k, v in params.items() %}
    {{ k }}: {{ v }}
  {%- endfor -%}
  {% endif %}
  sources:
  {%- if sources -%}
  {%- for src in sources %}
    - "{{ src }}"
  {% endfor -%}
  {%- endif -%}
  blackbox_ports:
  {%- for k, v in ports.items() %}
    {{ k }}: "{{ v }}"
  {%- endfor -%}
{% endif %}

