{#
  DUT.scala.j2
  ============
  Generates the Chisel BlackBox wrapper that exposes the user's Verilog IP to
  the FireSim bridge infrastructure.

  Context variables used
  ----------------------
  top_module      str                    config.design.top_module
  package_name    str                    config.project.package_name
  clock_port      str | None             blackbox_ports key with value "in clock"
  reset_port      str | None             blackbox_ports key with value "in reset"
  verilog_file    str | None             basename of design.sources[0]

  unique_bridges  dict[str, BridgeInstance]
    Keyed by bridge type id.  Used for DUT-level import statements.
    bridge_def.scala_templates.dut_imports  — path to import snippet template

  instances       list[BridgeInstance]
    One entry per bridge instance in declaration order.  Used to include the
    per-bridge port declaration snippet inside the IO Bundle.
    instance.scala_templates.ports          — path to port snippet template
    instance.name                           — bridge instance name
    instance.port_map                       — {bridge_port: bb_port}

  NOTE: all scala_templates paths must be resolvable by the Jinja2
  Environment loader (relative to the template root directory).
#}
// =============================================================================
//  {{ top_module }}.scala
// @GENERATED_BY_FSLAB — do not edit by hand.
// =============================================================================
package {{ package_name }}

import chisel3._
import chisel3.util._

// ── Bridge DUT-Level Imports ──────────────────────────────────────────────────
{% for b_type, bridge_def in unique_bridges.items() %}
{% if bridge_def.scala_templates.dut_imports %}
{% include bridge_def.scala_templates.dut_imports %}
{% endif %}
{% endfor %}

// ── DUT IO Bundle ─────────────────────────────────────────────────────────────
class {{ top_module }}IO extends Bundle {
{% if clock_port %}
  val {{ clock_port }} = Input(Clock())
{%- endif -%}
{%- if reset_port %}
  val {{ reset_port }} = Input(Bool())
{% endif %}

  // ── Per-Bridge Port Declarations (one snippet per bridge instance) ─────────
{% for instance in instances %}
  // {{ instance.label }} — instance: {{ instance.name }}
{% if instance.scala_templates.ports %}
{% include instance.scala_templates.ports %}
{% endif -%}
{% endfor -%}
}

// ── BlackBox Wrapper ───────────────────────────────────────────────────────────
class {{ top_module }} extends BlackBox with HasBlackBoxPath {
  val io = IO(new {{ top_module }}IO)
{% if verilog_files %}
{% for verilog_file in verilog_files %}
  addPath("{{ verilog_file }}")
{% endfor %}
{% endif %}
}