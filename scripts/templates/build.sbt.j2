// =============================================================================
//  build.sbt — {{ target_name }}
//  Generated by new-target.py on {{ generated_date }}
//
//  This project is the SBT root.  It depends on firesim-lab (for the common
//  bridge library) and on firesim itself — both via ProjectRef so that all
//  three build together incrementally with a single `sbt compile`.
//
//  Required environment variables (set in env.sh):
//    FIRESIM_ROOT      — path to the firesim checkout (e.g. /firesim)
//    FIRESIM_LAB_ROOT  — path to the firesim-lab repo  (e.g. /firesim-lab)
// =============================================================================

// ── Resolve dependency roots from environment ─────────────────────────────────
val firesimRoot = file(
  sys.env.getOrElse("FIRESIM_ROOT", "../firesim")
) / "sim"

val firesimLabRoot = file(
  sys.env.getOrElse("FIRESIM_LAB_ROOT", "../firesim-lab")
)

// ── ProjectRef bindings ───────────────────────────────────────────────────────
// Bind to firesim's own lazy vals (defined in firesim/sim/build.sbt)
lazy val firesimLib  = ProjectRef(firesimRoot, "firesim")
lazy val midas       = ProjectRef(firesimRoot, "midas")
lazy val targetutils = ProjectRef(firesimRoot, "targetutils")

// Bind to firesim-lab's common bridge library
// ("common" must match the lazy val name in firesim-lab/build.sbt)
lazy val common = ProjectRef(firesimLabRoot, "common")

// ── This target ───────────────────────────────────────────────────────────────
lazy val {{ sbt_project }} = (project in file("."))
  .dependsOn(common, firesimLib, midas, targetutils)
  .settings(
    name          := "{{ target_name }}",
    organization  := "{{ scala_package }}",
    scalaVersion  := "2.13.10",     // must match firesim's scalaVersion exactly
    scalacOptions ++= Seq("-deprecation", "-feature", "-unchecked"),

    Compile / unmanagedResourceDirectories +=
      baseDirectory.value / "src" / "main" / "resources",
  )

// Root alias so plain `sbt compile` works without specifying a project
lazy val root = {{ sbt_project }}
