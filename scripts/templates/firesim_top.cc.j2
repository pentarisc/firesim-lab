// =============================================================================
//  firesim_top.cc — {{ target_name }}
//  Generated by new-target.py on {{ generated_date }}
//  Bridges enabled: {{ enabled_bridge_ids | join(', ') or 'none' }}
//
//  This file defines the simulation class and registers bridge drivers.
//  Bridge headers are compiled in/out via -DENABLE_*_BRIDGE flags set by
//  the common makefrag fragments included in config.mk.
// =============================================================================

#include "core/firesim_top.h"

// ── Bridge driver headers ─────────────────────────────────────────────────────
// Each header contains its own #ifdef guard so it is safe to include even
// when the bridge is absent from the target.
{% for bridge in enabled_bridges %}
{% if bridge.cpp_header %}
#ifdef {{ bridge.cpp_define }}
#  include "bridges/{{ bridge.cpp_header }}"
#endif
{% endif %}
{% endfor %}
{% if not enabled_bridges %}
// No bridges selected — only the FASED base-class auto-registration applies.
{% endif %}

// =============================================================================

class {{ sim_class }} final : public firesim_top_t {
public:
  {{ sim_class }}(const std::vector<std::string>& args)
    : firesim_top_t(args)
  {
    // ──────────────────────────────────────────────────────────────────────────
    //  FASED memory model
    //  Registered automatically by firesim_top_t — no action required here.
    // ──────────────────────────────────────────────────────────────────────────
{% for bridge in enabled_bridges %}
{% if bridge.driver_class %}

    // ── {{ bridge.label }} ───────────────────────────────────────────────────
{% for idx in range(bridge.max_instances) %}
#if defined({{ bridge.cpp_define }}) && defined({{ bridge.module_macro_prefix }}_{{ idx }}_PRESENT)
    {{ bridge.module_macro_prefix }}_{{ idx }}_substruct_create;
    add_bridge_driver({{ bridge.constructor_template
        | replace('{struct}', bridge.module_macro_prefix ~ '_' ~ idx ~ '_substruct')
        | replace('{idx}', idx | string)
        | replace('{args}', 'args') }});
#endif
{% endfor %}
{% endif %}
{% endfor %}
  }

  virtual ~{{ sim_class }}() {}
};

// =============================================================================
//  main() — required entry point
//  TEST_MAIN instantiates {{ sim_class }} and runs the simulation loop.
// =============================================================================
TEST_MAIN({{ sim_class }})
