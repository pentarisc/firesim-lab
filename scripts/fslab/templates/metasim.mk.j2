# =============================================================================
#  metasim.mk — {{ target_name }}
#  Generated by init-target on {{ generated_date }}
# =============================================================================

TIMEOUT_CYCLES ?= -1

# ── Runtime plusargs ──────────────────────────────────────────────────────────
# Assembled from all enabled bridges. Override via ARGS= on the command line.
#
{% for bridge in enabled_bridges %}
{% for pa in bridge.runtime_plusargs %}
#   {{ pa.flag }}
#       {{ pa.description }}
{% endfor %}
{% endfor %}
{% if not enabled_bridges %}
# No bridges enabled — no bridge-specific plusargs.
{% endif %}

# Default plusargs for this target (edit as needed)
TARGET_PLUSARGS ?= \
{% for bridge in enabled_bridges %}
{% if bridge.id == 'uart' %}
  +uart-loopback \
{% endif %}
{% endfor %}
  +timeout=$(TIMEOUT_CYCLES)

# ── Verilator ─────────────────────────────────────────────────────────────────
verilator: $(VERILATOR_BINARY)
	cd $(GENERATED_DIR) && \
	$(VERILATOR_BINARY) \
	  $(TARGET_PLUSARGS) \
	  $(ARGS)

verilator-debug: $(VERILATOR_DEBUG_BINARY)
	cd $(GENERATED_DIR) && \
	$(VERILATOR_DEBUG_BINARY) \
	  $(TARGET_PLUSARGS) \
	  +waveform=$(GENERATED_DIR)/{{ design }}.vpd \
	  $(ARGS)

# ── VCS ───────────────────────────────────────────────────────────────────────
run-vcs: $(VCS_BINARY)
	cd $(GENERATED_DIR) && \
	$(VCS_BINARY) $(TARGET_PLUSARGS) $(ARGS)

run-vcs-debug: $(VCS_DEBUG_BINARY)
	cd $(GENERATED_DIR) && \
	$(VCS_DEBUG_BINARY) \
	  $(TARGET_PLUSARGS) \
	  +vcdplusfile=$(GENERATED_DIR)/{{ design }}.vpd \
	  $(ARGS)

.PHONY: verilator verilator-debug run-vcs run-vcs-debug
