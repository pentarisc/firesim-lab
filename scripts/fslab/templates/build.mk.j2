# =============================================================================
#  build.mk — {{ target_name }}
#  Generated by init-target on {{ generated_date }}
# =============================================================================

GENERATOR_CLASS := $(GENERATOR_PACKAGE).Generator

$(FIRRTL_FILE) $(ANNO_FILE): \
    $(shell find $(target_base_dir)/src/main/scala -name "*.scala" 2>/dev/null)
	mkdir -p $(GENERATED_DIR)
	$(SBT_COMMAND) \
	  "project $(SBT_PROJECT)" \
	  "runMain $(GENERATOR_CLASS) \
	    --target-dir $(GENERATED_DIR) \
	    --top-module $(DESIGN) \
	    --target-config $(TARGET_CONFIG) \
	    --platform-config $(PLATFORM_CONFIG)"

.PHONY: firesim_target_symlink_hook

# Symlinks common GG Scala AND target-specific GG Scala into firesim-lib.
# TARGET_COPY_TO_MIDAS_SCALA_DIRS is the union set from config.mk.
firesim_target_symlink_hook:
	@echo "[{{ target_name }}] symlinking GoldenGate bridge Scala dirs:"
	@for dir in $(TARGET_COPY_TO_MIDAS_SCALA_DIRS); do \
	  if [ -d "$$dir" ]; then \
	    linkname=$(FIRESIM_SIM)/firesim-lib/src/main/scala/$$(basename $$dir); \
	    ln -sfn $$dir $$linkname; \
	    echo "  $$(basename $$dir) -> $$dir"; \
	  fi \
	done
