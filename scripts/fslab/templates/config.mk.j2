# =============================================================================
#  config.mk — {{ target_name }}
#  Generated by init-target on {{ generated_date }}
#  Bridges enabled: {{ enabled_bridge_ids | join(', ') or 'none' }}
#
#  Requires FIRESIM_LAB_ROOT to be set (done by env.sh).
# =============================================================================

target_base_dir  := $(abspath $(dir $(lastword $(MAKEFILE_LIST)))/..)

# Reference common bridge fragments from firesim-lab via environment variable.
# This is the key difference from an in-tree target: we don't use a relative
# path so this project can live anywhere on the filesystem.
FIRESIM_LAB_ROOT ?= /firesim-lab
COMMON_MAKEFRAG  := $(FIRESIM_LAB_ROOT)/targets/common/makefrag

# ── Pull in common base paths ─────────────────────────────────────────────────
include $(COMMON_MAKEFRAG)/common_base.mk

# ── Opt-in bridge fragments ───────────────────────────────────────────────────
{% for bridge in enabled_bridges %}
include $(COMMON_MAKEFRAG)/{{ bridge.makefrag }}
{% endfor %}
{% if not enabled_bridges %}
# No bridges selected. To add one later:
#   include $(COMMON_MAKEFRAG)/uart.mk
#   include $(COMMON_MAKEFRAG)/fased.mk
{% endif %}

# ── GoldenGate Scala dirs ─────────────────────────────────────────────────────
# Symlinked into firesim-lib by firesim_target_symlink_hook.
# Includes common GG impls for enabled bridges + this target's own GG scala.
TARGET_COPY_TO_MIDAS_SCALA_DIRS := \
  $(COMMON_GG_SCALA_DIRS) \
  $(target_base_dir)/src/main/goldengateimplementations/scala

# ── SBT / generator settings (overridden by target Makefile) ─────────────────
SBT_PROJECT       ?= {{ sbt_project }}
DESIGN            ?= {{ design }}
TARGET_CONFIG     ?= {{ scala_package }}.{{ target_config_class }}
PLATFORM_CONFIG   ?= {{ scala_package }}.{{ platform_config_class }}
