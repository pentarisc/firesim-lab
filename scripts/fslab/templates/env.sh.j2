#!/usr/bin/env bash
# =============================================================================
#  env.sh — {{ target_name }}
#  Generated by init-target on {{ generated_date }}
#
#  Source this before running any make or sbt command:
#    source env.sh
#
#  Override any variable by setting it before sourcing, e.g.:
#    export FIRESIM_ROOT=/custom/path && source env.sh
# =============================================================================

cd $FIRESIM_ROOT && source sourceme-manager.sh --skip-ssh-setup
cd -

# Absolute path to this target's root directory (works from any cwd)
export TARGET_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Dependency roots ──────────────────────────────────────────────────────────
# Path to the immutable firesim checkout (inside Docker: /firesim)
export FIRESIM_ROOT="${FIRESIM_ROOT:-/firesim}"

# Path to the firesim-lab framework repo (inside Docker: /firesim-lab)
export FIRESIM_LAB_ROOT="${FIRESIM_LAB_ROOT:-/firesim-lab}"

# ── Build outputs ─────────────────────────────────────────────────────────────
# Generated Verilog, headers, and the compiled simulator binary all land here.
# This path is on the user target volume so outputs survive container restarts.
export GENERATED_DIR="${TARGET_ROOT}/generated-src"

# ── Convenience: override SBT_COMMAND so firesim's Makefile uses our root ─────
# firesim/sim/Makefile invokes $(SBT_COMMAND) internally.  By setting it here
# we redirect SBT to use THIS directory's build.sbt instead of firesim's.
export SBT_COMMAND="sbt"

echo "[{{ target_name }}] TARGET_ROOT      = ${TARGET_ROOT}"
echo "[{{ target_name }}] FIRESIM_ROOT     = ${FIRESIM_ROOT}"
echo "[{{ target_name }}] FIRESIM_LAB_ROOT = ${FIRESIM_LAB_ROOT}"
echo "[{{ target_name }}] GENERATED_DIR    = ${GENERATED_DIR}"
echo "[{{ target_name }}] SBT_COMMAND      = ${SBT_COMMAND}"
