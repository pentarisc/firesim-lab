# =============================================================================
#  Makefile — {{ target_name }}
#  Generated by init-target on {{ generated_date }}
#
#  This is the only Makefile you need.  It delegates to firesim/sim/Makefile
#  with all variables pre-filled for this target.
#
#  Usage:
#    source env.sh          # set FIRESIM_ROOT, FIRESIM_LAB_ROOT, etc.
#    make compile         # Chisel → FIRRTL → GoldenGate Verilog
#    make verilator         # compile the Verilator simulator binary
#    make run               # run with Verilator
#    make run-debug         # run with waveform dump
#    make vcs               # compile with VCS (if available)
#    make clean             # remove generated-src/
#
#  Pass extra simulator plusargs via ARGS=:
#    make run ARGS="+uart-out=/tmp/uart.log"
# =============================================================================

# ── Paths (set by env.sh; fall back to Docker-standard locations) ─────────────
TARGET_ROOT      ?= $(shell pwd)
FIRESIM_ROOT     ?= /firesim
FIRESIM_LAB_ROOT ?= /firesim-lab
FIRESIM_SIM      := $(FIRESIM_ROOT)/sim

# ── Target identity ───────────────────────────────────────────────────────────
DESIGN           := {{ design }}
TARGET_CONFIG    := {{ scala_package }}.{{ target_config_class }}
PLATFORM_CONFIG  := {{ scala_package }}.{{ platform_config_class }}
SBT_PROJECT      := {{ sbt_project }}
MAKEFRAG_DIR     := $(TARGET_ROOT)/makefrag

# ── Generated output directory ────────────────────────────────────────────────
# Defaults to generated-src/ inside this target's directory so outputs are
# kept with the project and survive Docker container restarts.
GENERATED_DIR    ?= $(TARGET_ROOT)/generated-src

# ── SBT command override ──────────────────────────────────────────────────────
# Redirects firesim's internal $(SBT_COMMAND) calls to use our build.sbt.
# env.sh sets this; the export here ensures sub-make sees it too.
export SBT_COMMAND ?= sbt \
  --rootdir $(TARGET_ROOT) \
  -Xmx4g -Xss8m \
  -Dsbt.supershell=false

# ── Common firesim make invocation ───────────────────────────────────────────
FIRESIM_MAKE := $(MAKE) -C $(FIRESIM_SIM) \
  TARGET_PROJECT_MAKEFRAG=$(MAKEFRAG_DIR) \
  DESIGN=$(DESIGN) \
  TARGET_CONFIG=$(TARGET_CONFIG) \
  PLATFORM_CONFIG=$(PLATFORM_CONFIG) \
  SBT_PROJECT=$(SBT_PROJECT) \
  GENERATED_DIR=$(GENERATED_DIR)

# ── Targets ───────────────────────────────────────────────────────────────────
.PHONY: compile verilator vcs run run-debug run-vcs run-vcs-debug clean help

## compile: Run Chisel elaboration → FIRRTL + GoldenGate Verilog
compile:
	$(FIRESIM_MAKE) compile

## verilator: Compile the Verilator software simulator binary
verilator:
	$(FIRESIM_MAKE) verilator

## vcs: Compile the VCS software simulator binary
vcs:
	$(FIRESIM_MAKE) vcs

## run: Run Verilator simulation (set ARGS= for extra plusargs)
run:
	$(FIRESIM_MAKE) verilator ARGS="$(ARGS)"

## run-debug: Run Verilator simulation with waveform dump
run-debug:
	$(FIRESIM_MAKE) verilator-debug ARGS="$(ARGS)"

## run-vcs: Run VCS simulation
run-vcs:
	$(FIRESIM_MAKE) run-vcs ARGS="$(ARGS)"

## run-vcs-debug: Run VCS simulation with waveform dump
run-vcs-debug:
	$(FIRESIM_MAKE) run-vcs-debug ARGS="$(ARGS)"

## clean: Remove all generated build artifacts
clean:
	$(FIRESIM_MAKE) clean
	rm -rf $(GENERATED_DIR)

## help: Show this message
help:
	@echo ""
	@echo "  {{ target_name }} — FireSim target"
	@echo ""
	@echo "  Environment (set via env.sh):"
	@echo "    FIRESIM_ROOT     = $(FIRESIM_ROOT)"
	@echo "    FIRESIM_LAB_ROOT = $(FIRESIM_LAB_ROOT)"
	@echo "    GENERATED_DIR    = $(GENERATED_DIR)"
	@echo ""
	@echo "  Bridges enabled: {{ enabled_bridge_ids | join(', ') or 'none' }}"
	@echo ""
	@grep -E '^##' $(MAKEFILE_LIST) | sed 's/^## /  make /'
	@echo ""
{% if enabled_bridges %}
	@echo "  Runtime plusargs:"
{% for bridge in enabled_bridges %}
{% for pa in bridge.runtime_plusargs %}
	@echo "    {{ pa.flag }}"
	@echo "        {{ pa.description }}"
{% endfor %}
{% endfor %}
	@echo ""
{% endif %}
